# www → non-www (canonical: https://zotopie.com)
https://www.zotopie.com/* https://zotopie.com/:splat 301

# HTTP → HTTPS fallback
http://zotopie.com/* https://zotopie.com/:splat 301
http://www.zotopie.com/* https://zotopie.com/:splat 301

# Sitemap alias — Astro generates sitemap-index.xml, not sitemap.xml
/sitemap.xml  /sitemap-index.xml  301

# Redirect bare category paths to trailing-slash versions
/reddit  /reddit/  301
/threads  /threads/  301
/extensions  /extensions/  301
/marketing  /marketing/  301
/blog  /blog/  301

# 404 fallback
/*  /404  404
