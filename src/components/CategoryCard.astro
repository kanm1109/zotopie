---
const { category, toolCount = 0 } = Astro.props;

const iconMap: Record<string, { emoji: string; color: string; bg: string }> = {
  'community-growth':              { emoji: '👥', color: '#6366F1', bg: '#EEF2FF' },
  'social-media-management':       { emoji: '📱', color: '#EC4899', bg: '#FDF2F8' },
  'content-ai-creation':           { emoji: '✨', color: '#7C3AED', bg: '#F5F3FF' },
  'seo-search':                    { emoji: '🔍', color: '#D97706', bg: '#FFFBEB' },
  'marketing-lead-generation':     { emoji: '📣', color: '#EF4444', bg: '#FEF2F2' },
  'link-tracking':                 { emoji: '🔗', color: '#0891B2', bg: '#ECFEFF' },
  'workflow-automation':            { emoji: '⚡', color: '#EA580C', bg: '#FFF7ED' },
  'data-analytics':                { emoji: '📊', color: '#8B5CF6', bg: '#F5F3FF' },
  'productivity-knowledge-management': { emoji: '🚀', color: '#059669', bg: '#ECFDF5' },
  'infrastructure-hosting':        { emoji: '☁️', color: '#2563EB', bg: '#EFF6FF' },
  'ecommerce-monetization':        { emoji: '🛒', color: '#C2410C', bg: '#FFF7ED' },
};

const icon = iconMap[category.slug] ?? { emoji: '🔧', color: '#7C3AED', bg: '#F5F3FF' };
---

<a href={`/category/${category.slug}`} class="cat-card">
  <div class="cat-icon" style={`background:${icon.bg};color:${icon.color}`}>
    <span aria-hidden="true">{icon.emoji}</span>
  </div>
  <div class="cat-body">
    <h3 class="cat-name">{category.name}</h3>
    <p class="cat-desc">{category.description}</p>
    <span class="cat-count" style={`color:${icon.color};background:${icon.bg}`}>{toolCount} {toolCount === 1 ? "tool" : "tools"} →</span>
  </div>
</a>

<style>
  .cat-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    border: 1.5px solid #E8ECF0;
    border-radius: 16px;
    padding: 20px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
  }
  .cat-card:hover {
    border-color: var(--c-purple, #7C3AED);
    box-shadow: 0 8px 28px rgba(124,58,237,0.10);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .cat-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    flex-shrink: 0;
    line-height: 1;
  }
  .cat-body {
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 0;
  }
  .cat-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0;
    line-height: 1.3;
  }
  .cat-desc {
    font-size: 0.815rem;
    color: #647488;
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cat-count {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 10px;
    display: inline-block;
    width: fit-content;
    margin-top: 2px;
  }
</style>
