---
import ToolLogo from "./ToolLogo.astro";
const { tool } = Astro.props;

const isFree = tool.pricing === "Free" || tool.pricing === "Freemium";
const priceLabel = tool.startingPrice
  ? (isFree ? `Free / ${tool.startingPrice}` : tool.startingPrice)
  : tool.pricing;
---

<div class="tool-card">
  <div class="tool-top">
    <div class="tool-id">
      <ToolLogo tool={tool} size={38} />
      <div class="tool-meta">
        <h3 class="tool-name">
          <a href={`/reviews/${tool.slug}`}>{tool.name}</a>
        </h3>
        <span class:list={["tool-pricing", { "pricing-free": isFree }]}>{priceLabel}</span>
      </div>
    </div>
    <span class="tool-rating">
      <span class="rating-star">★</span>{tool.rating}
    </span>
  </div>
  <p class="tool-desc">{tool.description}</p>
  <div class="tool-footer">
    <a href={`/reviews/${tool.slug}`} class="view-btn">Read Review →</a>
  </div>
</div>

<style>
  .tool-card {
    border: 1.5px solid #E8ECF0;
    border-radius: 16px;
    padding: 22px;
    background: #fff;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
    position: relative;
    overflow: hidden;
  }
  .tool-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #7C3AED, #6366F1);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .tool-card:hover {
    border-color: #C4B5FD;
    box-shadow: 0 8px 28px rgba(124,58,237,0.12), 0 2px 8px rgba(0,0,0,0.04);
    transform: translateY(-2px);
  }
  .tool-card:hover::before { opacity: 1; }

  .tool-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }
  .tool-id {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }
  .tool-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .tool-name {
    font-size: 1.02rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }
  .tool-name a {
    color: #0F172A;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }
  .tool-name a:hover { color: #7C3AED; }

  .tool-pricing {
    font-size: 0.72rem;
    font-weight: 600;
    color: #647488;
    background: #F1F5F9;
    padding: 2px 8px;
    border-radius: 10px;
    display: inline-block;
    width: fit-content;
  }
  .pricing-free {
    color: #059669;
    background: #DCFCE7;
  }

  .tool-rating {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 0.85rem;
    font-weight: 700;
    color: #92400E;
    background: #FEF3C7;
    border: 1px solid #FDE68A;
    padding: 3px 10px;
    border-radius: 20px;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .rating-star {
    color: #F59E0B;
    font-size: 0.82rem;
  }

  .tool-desc {
    font-size: 0.875rem;
    color: #647488;
    margin: 0;
    flex: 1;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tool-footer {
    margin-top: 2px;
  }

  .view-btn {
    display: inline-flex;
    align-items: center;
    font-size: 0.82rem;
    font-weight: 700;
    color: #7C3AED;
    background: #F5F3FF;
    border: 1.5px solid #DDD6FE;
    padding: 6px 16px;
    border-radius: 20px;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .view-btn:hover {
    background: #7C3AED;
    border-color: #7C3AED;
    color: #fff;
    text-decoration: none;
  }
</style>
