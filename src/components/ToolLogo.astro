---
import iconData from '../data/generated/icon-data.json';
import { getInitials, getAvatarColor } from '../utils/logo';

const { tool, size = 32 } = Astro.props;

const slug     = tool.simple_icon ?? '';
const icon     = slug ? (iconData as Record<string, { hex: string; path: string }>)[slug] : null;
const initials = getInitials(tool.name);
const color    = getAvatarColor(tool.slug);
const fs       = Math.round(size * 0.38);
---

{icon ? (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    class="tl-svg"
    style={`fill:#${icon.hex}`}
    aria-label={`${tool.name} logo`}
    role="img"
  >
    <path d={icon.path} />
  </svg>
) : (
  <span
    class="tl-fallback"
    style={`width:${size}px;height:${size}px;background:${color};font-size:${fs}px`}
    aria-hidden="true"
  >{initials}</span>
)}

<style>
  .tl-svg {
    border-radius: 6px;
    flex-shrink: 0;
    display: block;
    background: #f9fafb;
    padding: 2px;
    box-sizing: content-box;
  }
  .tl-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    color: #fff;
    font-weight: 700;
    flex-shrink: 0;
    line-height: 1;
    user-select: none;
    letter-spacing: 0.02em;
  }
</style>
