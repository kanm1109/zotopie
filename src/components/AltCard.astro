---
import ToolLogo from "./ToolLogo.astro";

const { tool, compareSlug } = Astro.props;
const price = tool.startingPrice
  ? (tool.pricing === "Free" || tool.pricing === "Freemium"
      ? `Free / ${tool.startingPrice}`
      : tool.startingPrice)
  : tool.pricing;
const tryLabel = (tool.pricing === "Free" || tool.pricing === "Freemium") ? "Try Free →" : "Visit →";
---

<div class="alt-card">
  <a href={`/reviews/${tool.slug}`} class="alt-card-link">
    <div class="alt-logo">
      <ToolLogo tool={tool} size={44} />
    </div>
    <div class="alt-body">
      <div class="alt-header">
        <span class="alt-name">{tool.name}</span>
        <span class="alt-rating">★ {tool.rating}</span>
      </div>
      <p class="alt-desc">{tool.description}</p>
      <span class="alt-price">{price}</span>
    </div>
  </a>
  <div class="alt-actions">
    {compareSlug && (
      <a href={`/compare/${compareSlug}/`} class="alt-cmp-btn">Compare →</a>
    )}
    <a href={`/go/${tool.slug}`}
       class="alt-try-btn"
       rel={tool.affiliate ? "sponsored noopener" : "noopener"}
       target="_blank">
      {tryLabel}
    </a>
    <a href={`/reviews/${tool.slug}`} class="alt-review-btn">Review →</a>
  </div>
</div>

<style>
  .alt-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #fff;
    transition: border-color 0.18s, box-shadow 0.18s, background 0.18s, transform 0.15s;
  }
  .alt-card:hover {
    border-color: #93c5fd;
    box-shadow: 0 6px 20px rgba(37,99,235,0.10);
    background: #fafbff;
    transform: translateY(-1px);
  }

  .alt-card-link {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
    min-width: 0;
    text-decoration: none;
    color: inherit;
  }

  .alt-logo { flex-shrink: 0; }

  .alt-body {
    flex: 1;
    min-width: 0;
  }
  .alt-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }
  .alt-name {
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
  }
  .alt-rating {
    font-size: 0.8rem;
    font-weight: 700;
    color: #d97706;
    background: #fef3c7;
    padding: 2px 8px;
    border-radius: 10px;
    flex-shrink: 0;
  }
  .alt-desc {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0 0 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .alt-price {
    font-size: 0.78rem;
    font-weight: 600;
    color: #9ca3af;
    background: #f3f4f6;
    padding: 2px 8px;
    border-radius: 8px;
  }

  .alt-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    margin-left: 8px;
  }

  .alt-cmp-btn {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #7c3aed;
    background: #f5f3ff;
    border: 1px solid #e9d5ff;
    padding: 5px 12px;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, border-color 0.15s;
  }
  .alt-cmp-btn:hover {
    background: #ede9fe;
    border-color: #c4b5fd;
    text-decoration: none;
  }

  .alt-try-btn {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    background: #2563eb;
    padding: 5px 14px;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .alt-try-btn:hover {
    background: #1d4ed8;
    text-decoration: none;
  }

  .alt-review-btn {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #6b7280;
    white-space: nowrap;
    text-decoration: none;
  }
  .alt-review-btn:hover {
    color: #2563eb;
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .alt-cmp-btn { display: none; }
    .alt-review-btn { display: none; }
    .alt-desc { -webkit-line-clamp: 1; }
  }
  @media (max-width: 400px) {
    .alt-actions { margin-left: 4px; }
    .alt-try-btn { padding: 5px 10px; font-size: 0.78rem; }
  }
</style>
