---
import ToolLogo from "./ToolLogo.astro";

const { tool } = Astro.props;
const price = tool.startingPrice
  ? `from ${tool.startingPrice}`
  : tool.pricing;
---

<a href={`/reviews/${tool.slug}`} class="alt-card">
  <div class="alt-logo">
    <ToolLogo tool={tool} size={44} />
  </div>
  <div class="alt-body">
    <div class="alt-header">
      <span class="alt-name">{tool.name}</span>
      <span class="alt-rating">★ {tool.rating}</span>
    </div>
    <p class="alt-desc">{tool.description}</p>
    <span class="alt-price">{price}</span>
  </div>
  <div class="alt-action">
    <span class="alt-btn">Read Review &rarr;</span>
  </div>
</a>

<style>
  .alt-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
  }
  .alt-card:hover {
    border-color: #2563eb;
    box-shadow: 0 2px 14px rgba(37,99,235,0.09);
    background: #fafbff;
    text-decoration: none;
  }

  .alt-logo { flex-shrink: 0; }

  .alt-body {
    flex: 1;
    min-width: 0;
  }
  .alt-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }
  .alt-name {
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
  }
  .alt-rating {
    font-size: 0.8rem;
    font-weight: 700;
    color: #d97706;
    background: #fef3c7;
    padding: 2px 8px;
    border-radius: 10px;
    flex-shrink: 0;
  }
  .alt-desc {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0 0 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .alt-price {
    font-size: 0.78rem;
    font-weight: 600;
    color: #9ca3af;
    background: #f3f4f6;
    padding: 2px 8px;
    border-radius: 8px;
  }

  .alt-action {
    flex-shrink: 0;
    margin-left: 8px;
  }
  .alt-btn {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #2563eb;
    white-space: nowrap;
  }
  .alt-card:hover .alt-btn {
    text-decoration: underline;
  }

  @media (max-width: 560px) {
    .alt-action { display: none; }
    .alt-desc { -webkit-line-clamp: 1; }
  }
</style>
