---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import BaseHead from '../../components/BaseHead.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_URL } from '../../consts';

export async function getStaticPaths() {
	const [blogs, reddits, threads, extensions, marketings] = await Promise.all([
		getCollection('blog', ({ data }) => !data.draft),
		getCollection('reddit', ({ data }) => !data.draft),
		getCollection('threads', ({ data }) => !data.draft),
		getCollection('extensions', ({ data }) => !data.draft),
		getCollection('marketing', ({ data }) => !data.draft),
	]);

	const allPosts = [
		...blogs.map((p) => ({ ...p, collection: 'blog' as const })),
		...reddits.map((p) => ({ ...p, collection: 'reddit' as const })),
		...threads.map((p) => ({ ...p, collection: 'threads' as const })),
		...extensions.map((p) => ({ ...p, collection: 'extensions' as const })),
		...marketings.map((p) => ({ ...p, collection: 'marketing' as const })),
	];

	const tagMap = new Map<string, typeof allPosts>();
	for (const post of allPosts) {
		for (const tag of post.data.tags) {
			if (!tagMap.has(tag)) tagMap.set(tag, []);
			tagMap.get(tag)!.push(post);
		}
	}

	return Array.from(tagMap.entries()).map(([tag, posts]) => ({
		params: { tag },
		props: {
			posts: posts.sort(
				(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
			),
		},
	}));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={`#${tag} articles`}
			description={`All articles tagged with #${tag} on Zotopie.`}
			breadcrumbs={[
				{ name: 'Tags', url: `${SITE_URL}/tags/` },
				{ name: `#${tag}`, url: `${SITE_URL}/tags/${tag}/` },
			]}
		/>
	</head>
	<body>
		<Header />
		<main class="tag-main">
			<div class="tag-header">
				<Breadcrumb
					items={[
						{ name: 'Tags', url: '/tags/' },
						{ name: `#${tag}`, url: `/tags/${tag}/` },
					]}
				/>
				<h1>#{tag}</h1>
				<p class="tag-count">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
			</div>
			<div class="posts-grid">
				{posts.map((post) => (
					<ArticleCard
						title={post.data.title}
						description={post.data.description}
						publishDate={post.data.publishDate}
						slug={post.id}
						category={post.collection}
						tags={post.data.tags}
						featuredImage={post.data.featuredImage}
					/>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.tag-main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
	}
	.tag-header { margin-bottom: 2.5rem; }
	h1 {
		font-size: 2.4rem;
		margin: 0.25rem 0 0.5rem;
	}
	.tag-count {
		color: rgb(var(--gray));
		margin: 0;
		font-size: 1rem;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
	}
	@media (max-width: 640px) {
		.posts-grid { grid-template-columns: 1fr; }
	}
</style>
