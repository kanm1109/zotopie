---
import tools from "../../data/generated/tools-enriched.json";

export async function getStaticPaths() {
  return tools
    .filter((t) => t.website)
    .map((t) => ({
      params: { slug: t.slug },
      props: { tool: t },
    }));
}

const { tool } = Astro.props;
const isAffiliate = tool.affiliate === true;
const dest = (isAffiliate && tool.affiliateUrl) ? tool.affiliateUrl : tool.website;
const GA_ID = import.meta.env.PUBLIC_GA_ID ?? '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, nofollow" />
    <!-- Delay gives GA4 time to beacon; JS redirect fires faster (~300ms) -->
    <meta http-equiv="refresh" content={`3;url=${dest}`} />
    <title>Redirecting to {tool.name}…</title>
    {GA_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID, { send_page_view: false });
        </script>
      </>
    )}
    <script define:vars={{ slug: tool.slug, dest, isAffiliate, toolName: tool.name, GA_ID }}>
      // 1. localStorage (per-browser debug data)
      try {
        const key = "ztp_clicks";
        const raw = localStorage.getItem(key);
        const data = raw ? JSON.parse(raw) : {};
        const now = Date.now();
        data[slug] = data[slug] ?? { count: 0, first: now };
        data[slug].count += 1;
        data[slug].last = now;
        if (isAffiliate) data[slug].affiliate = true;
        localStorage.setItem(key, JSON.stringify(data));
      } catch (_) {}

      // 2. GA4 affiliate_click event → redirect on callback
      var _redirected = false;
      function _doRedirect() {
        if (!_redirected) { _redirected = true; window.location.replace(dest); }
      }

      if (GA_ID && typeof gtag === 'function') {
        gtag('event', 'affiliate_click', {
          tool_name: toolName,
          tool_slug: slug,
          is_affiliate: isAffiliate,
          event_callback: _doRedirect,
        });
        // Fallback: redirect after 1.2s even if GA4 doesn't callback
        setTimeout(_doRedirect, 1200);
      } else {
        _doRedirect();
      }
    </script>
  </head>
  <body style="font-family:sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;background:#f9fafb;">
    <div style="text-align:center;max-width:400px;padding:32px;">
      <div style="font-size:2rem;margin-bottom:16px;">↗</div>
      <p style="color:#374151;font-size:1rem;margin-bottom:12px;">
        Taking you to <strong>{tool.name}</strong>…
      </p>
      <a
        href={dest}
        rel={isAffiliate ? "sponsored noopener" : "noopener"}
        style="display:inline-block;background:#2563eb;color:#fff;padding:10px 24px;border-radius:8px;text-decoration:none;font-size:0.95rem;font-weight:600;"
      >
        Continue to {tool.name} →
      </a>
      {isAffiliate && (
        <p style="margin-top:14px;font-size:0.72rem;color:#9ca3af;">
          Affiliate link — we may earn a commission at no extra cost to you.
        </p>
      )}
      <p style="margin-top:20px;font-size:0.78rem;color:#9ca3af;">
        <a href="/" style="color:#6b7280;">Back to Zotopie</a>
      </p>
    </div>
  </body>
</html>
