---
import tools from "../data/generated/tools-enriched.json";
import taxonomies from "../data/taxonomies.json";
import MainLayout from "../layouts/MainLayout.astro";
import ToolCard from "../components/ToolCard.astro";
import CategoryCard from "../components/CategoryCard.astro";

const popularTools  = tools.filter((t) => t.featured).sort((a, b) => b.rating - a.rating).slice(0, 6);
const topRated      = [...tools].sort((a, b) => b.rating - a.rating).slice(0, 6);
const recentlyAdded = [...tools].sort((a, b) => b.addedDate.localeCompare(a.addedDate)).slice(0, 6);

const categoriesWithCount = taxonomies.map((cat) => ({
  ...cat,
  toolCount: tools.filter((t) => t.categories.includes(cat.slug)).length,
}));
---

<MainLayout
  title="Zotopie — Find the Best Software Tools"
  description="Discover reviews, comparisons and alternatives for the best software tools. Find the right tool for your workflow."
>

  <!-- HERO -->
  <section class="hero">
    <h1>Discover The Best<br />Software Tools</h1>
    <p class="hero-sub">Honest reviews. No fluff. Find the right tool for your workflow.</p>
    <div class="hero-actions">
      <a href="/reviews" class="btn-primary">Browse All Reviews</a>
      <a href="/search" class="btn-secondary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:-2px">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        Search Tools
      </a>
    </div>
  </section>

  <!-- BROWSE BY USE CASE -->
  <section class="section">
    <div class="section-header">
      <h2>Browse by Use Case</h2>
      <a href="/category" class="see-all">See all &rarr;</a>
    </div>
    <div class="cats-grid">
      {categoriesWithCount.map((cat) => (
        <CategoryCard category={cat} toolCount={cat.toolCount} />
      ))}
    </div>
  </section>

  <!-- POPULAR TOOLS -->
  {popularTools.length > 0 && (
    <section class="section">
      <div class="section-header">
        <div>
          <h2>Popular Tools</h2>
          <p class="section-sub">Handpicked tools trusted by thousands of teams</p>
        </div>
        <a href="/reviews" class="see-all">See all &rarr;</a>
      </div>
      <div class="tools-grid">
        {popularTools.map((tool) => (
          <ToolCard tool={tool} />
        ))}
      </div>
    </section>
  )}

  <!-- TOP RATED -->
  <section class="section">
    <div class="section-header">
      <div>
        <h2>Top Rated</h2>
        <p class="section-sub">Highest-rated tools based on our in-depth reviews</p>
      </div>
      <a href="/reviews" class="see-all">See all &rarr;</a>
    </div>
    <div class="tools-grid">
      {topRated.map((tool) => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </section>

  <!-- RECENTLY ADDED -->
  <section class="section">
    <div class="section-header">
      <div>
        <h2>Recently Added</h2>
        <p class="section-sub">Fresh reviews added to our database</p>
      </div>
      <a href="/reviews" class="see-all">See all &rarr;</a>
    </div>
    <div class="tools-grid">
      {recentlyAdded.map((tool) => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <h2>Find the right tool for your workflow</h2>
    <p>Honest reviews. No fluff.</p>
    <div class="cta-actions">
      <a href="/reviews" class="btn-primary">Browse All Reviews</a>
      <a href="/category" class="btn-secondary">Browse Categories</a>
    </div>
  </section>

</MainLayout>

<style>
  .hero {
    text-align: center;
    padding: 72px 0 64px;
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    color: #111827;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .hero-sub {
    font-size: 1.15rem;
    color: #6b7280;
    margin: 0 0 32px;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 28px;
    background: #2563eb;
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #1d4ed8; text-decoration: none; }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 28px;
    background: #fff;
    color: #374151;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover { border-color: #2563eb; color: #2563eb; text-decoration: none; }

  .section {
    padding: 48px 0;
    border-top: 1px solid #e5e7eb;
  }
  .section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
    gap: 16px;
  }
  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 4px;
  }
  .section-sub {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0;
  }
  .see-all {
    font-size: 0.875rem;
    font-weight: 600;
    color: #2563eb;
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 4px;
  }
  .see-all:hover { text-decoration: underline; }

  .cats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .cta-section {
    text-align: center;
    padding: 64px 24px;
    border-top: 1px solid #e5e7eb;
    background: #f9fafb;
    margin: 0 -24px;
  }
  .cta-section h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 8px;
  }
  .cta-section p {
    color: #6b7280;
    margin: 0 0 28px;
  }
  .cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .hero h1 { font-size: 2rem; }
    .cats-grid { grid-template-columns: 1fr 1fr; }
    .tools-grid { grid-template-columns: 1fr; }
    .section-header { flex-wrap: wrap; }
  }
</style>
