---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const [blogs, reddits, threads, extensions, marketings] = await Promise.all([
	getCollection('blog', ({ data }) => !data.draft),
	getCollection('reddit', ({ data }) => !data.draft),
	getCollection('threads', ({ data }) => !data.draft),
	getCollection('extensions', ({ data }) => !data.draft),
	getCollection('marketing', ({ data }) => !data.draft),
]);

const allPosts = [
	...blogs.map((p) => ({ ...p, collection: 'blog' as const })),
	...reddits.map((p) => ({ ...p, collection: 'reddit' as const })),
	...threads.map((p) => ({ ...p, collection: 'threads' as const })),
	...extensions.map((p) => ({ ...p, collection: 'extensions' as const })),
	...marketings.map((p) => ({ ...p, collection: 'marketing' as const })),
].sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const recent = allPosts.slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Software Reviews &amp;<br />Digital Marketing Insights</h1>
				<p class="hero-sub">
					Find the best tools, strategies, and guides for Reddit, Threads,
					browser extensions, and beyond.
				</p>
				<div class="hero-cats">
					{CATEGORIES.map((cat) => (
						<a href={`/${cat.slug}/`} class="cat-pill">{cat.name}</a>
					))}
				</div>
			</section>

			{recent.length > 0 && (
				<section class="recent-section">
					<h2>Latest Articles</h2>
					<div class="posts-grid">
						{recent.map((post, i) => (
							<ArticleCard
								title={post.data.title}
								description={post.data.description}
								publishDate={post.data.publishDate}
								slug={post.id}
								category={post.collection}
								tags={post.data.tags}
								featuredImage={post.data.featuredImage}
								featured={i === 0}
							/>
						))}
					</div>
				</section>
			)}

			<section class="cats-section">
				<h2>Browse by Category</h2>
				<div class="cats-grid">
					{CATEGORIES.map((cat) => (
						<a href={`/${cat.slug}/`} class="cat-card">
							<h3>{cat.name}</h3>
							<p>{cat.description}</p>
							<span class="cat-link">Browse {cat.name} &rarr;</span>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	.hero {
		text-align: center;
		padding: 4rem 1rem 3rem;
	}
	.hero h1 {
		font-size: 3rem;
		line-height: 1.1;
		margin-bottom: 1.25rem;
	}
	.hero-sub {
		font-size: 1.15rem;
		color: rgb(var(--gray));
		max-width: 560px;
		margin: 0 auto 2rem;
	}
	.hero-cats {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
	}
	.cat-pill {
		padding: 0.45rem 1.1rem;
		border: 2px solid var(--accent);
		border-radius: 50px;
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9rem;
		transition: all 0.2s;
		text-transform: capitalize;
	}
	.cat-pill:hover {
		background: var(--accent);
		color: white;
	}
	.recent-section,
	.cats-section {
		padding: 2rem 0 3rem;
	}
	.recent-section h2,
	.cats-section h2 {
		font-size: 1.8rem;
		margin-bottom: 1.5rem;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
	}
	.posts-grid > :first-child { grid-column: 1 / -1; }
	.cats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 1.5rem;
	}
	.cat-card {
		padding: 1.5rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		text-decoration: none;
		color: inherit;
		transition: all 0.2s;
		display: block;
	}
	.cat-card:hover {
		border-color: var(--accent);
		box-shadow: var(--box-shadow);
		transform: translateY(-2px);
	}
	.cat-card h3 {
		font-size: 1.15rem;
		margin-bottom: 0.5rem;
		color: var(--accent);
		text-transform: capitalize;
	}
	.cat-card p {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
		line-height: 1.4;
	}
	.cat-link {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.hero h1 { font-size: 2rem; }
		.posts-grid { grid-template-columns: 1fr; }
	}
</style>
