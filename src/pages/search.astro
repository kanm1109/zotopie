import tools from "../data/generated/tools-enriched.json";
import taxonomies from "../data/taxonomies.json";
import iconData from "../data/generated/icon-data.json";
import MainLayout from "../layouts/MainLayout.astro";

const toolsData      = JSON.stringify(tools);
const taxonomiesData = JSON.stringify(taxonomies);
const iconDataStr    = JSON.stringify(iconData);

// JSON-LD: WebSite (with SearchAction) + WebPage
const SITE = "https://zotopie.com";
const searchJsonLdStr = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${SITE}/#website`,
      url: `${SITE}/`,
      name: "Zotopie",
      description: "Find reviews, comparisons and alternatives for the best software tools.",
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${SITE}/search?q={search_term_string}`,
        },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "WebPage",
      "@id": `${SITE}/search/#webpage`,
      url: `${SITE}/search/`,
      name: "Search Tools | Zotopie",
      description: "Search across hundreds of software tool reviews by name, description, or category.",
      isPartOf: { "@id": `${SITE}/#website` },
      breadcrumb: {
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home",   item: `${SITE}/` },
          { "@type": "ListItem", position: 2, name: "Search" },
        ],
      },
    },
  ],
});
---

<MainLayout
  title="Search Tools | Zotopie"
  description="Search across hundreds of software tool reviews by name, description, or category."
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow" />
    <script type="application/ld+json" set:html={searchJsonLdStr} />
  </Fragment>

  <section class="search-hero">
    <h1>Search Tools</h1>
    <p class="search-sub">Find the right tool by name, description, or category.</p>

    <div class="search-box">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
        stroke="#9ca3af" stroke-width="2.5">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="q"
        type="search"
        placeholder="Try &quot;SEO&quot;, &quot;automation&quot;, &quot;scheduling&quot;Рђд"
        autocomplete="off"
        spellcheck="false"
        autofocus
      />
      <div id="ac-drop" class="ac-drop" role="listbox" aria-label="Search suggestions" hidden></div>
    </div>

    <div id="cat-filters" class="cat-filter-row" role="group" aria-label="Filter by category"></div>

    <p id="count" class="result-count" aria-live="polite"></p>
  </section>

  <div id="results" class="results-grid"></div>

</MainLayout>

<script define:vars={{ toolsData, taxonomiesData, iconDataStr }}>
const TOOLS = JSON.parse(toolsData);
const TAXONOMIES = JSON.parse(taxonomiesData);
const ICON_DATA = JSON.parse(iconDataStr);

const PALETTE = [
  '#7C3AED','#7c3aed','#059669',
  '#dc2626','#d97706','#0891b2',
  '#be185d','#16a34a',
];

function catName(slug) {
  const t = TAXONOMIES.find((x) => x.slug === slug);
  return t ? t.name : slug;
}

function initials(name) {
  return name.replace(/[^a-zA-Z0-9]/g, '').slice(0, 2).toUpperCase();
}

function logoHtml(tool) {
  const bg   = PALETTE[tool.slug.charCodeAt(0) % PALETTE.length];
  const fs   = Math.round(32 * 0.38);
  const icon = tool.simple_icon ? ICON_DATA[tool.simple_icon] : null;
  if (icon) {
    return `<svg width="32" height="32" viewBox="0 0 24 24" class="rc-logo-svg" style="fill:#${icon.hex}" aria-label="${esc(tool.name)} logo" role="img"><path d="${icon.path}"/></svg>`;
  }
  return `<span class="rc-logo-fb" style="width:32px;height:32px;background:${bg};font-size:${fs}px" aria-hidden="true">${initials(tool.name)}</span>`;
}

function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function highlight(text, q) {
  if (!q) return esc(text);
  const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
  return esc(text).replace(re, '<mark>$1</mark>');
}

function renderCard(tool, q) {
  const cats = tool.categories
    .map((s) => `<a href="/category/${s}" class="rc-cat">${esc(catName(s))}</a>`)
    .join('');
  const price = tool.startingPrice
    ? `${esc(tool.pricing)} ├ѓ┬и from ${esc(tool.startingPrice)}`
    : esc(tool.pricing);
  return `
<div class="rc-card">
  <div class="rc-top">
    <div class="rc-id">
      ${logoHtml(tool)}
      <h3 class="rc-name"><a href="/reviews/${tool.slug}">${highlight(tool.name, q)}</a></h3>
    </div>
    <span class="rc-rating">РўЁ ${tool.rating}</span>
  </div>
  <p class="rc-desc">${highlight(tool.description, q)}</p>
  ${cats ? `<div class="rc-cats">${cats}</div>` : ''}
  <div class="rc-footer">
    <span class="rc-pricing">${price}</span>
    <a href="/reviews/${tool.slug}" class="rc-link">View Review &rarr;</a>
  </div>
</div>`;
}

const POPULAR = ['SEO', 'Automation', 'AI Writing', 'Social Media'];
const POPULAR_HTML = `<div class="popular-wrap">
  <p class="popular-label">Popular Searches</p>
  <div class="popular-chips">
    ${POPULAR.map((t) => `<button class="popular-chip" onclick="fillSearch('${t}')">${t}</button>`).join('')}
  </div>
</div>`;

function fillSearch(term) {
  const input = document.getElementById('q');
  input.value = term;
  onInput();
  input.focus();
}

// ├бРђЮРѓг├бРђЮРѓг Relevance scoring ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
function scoreMatch(tool, q) {
  let score = 0;
  const nameLo = tool.name.toLowerCase();
  if (nameLo === q)                                        score += 30; // exact name
  else if (nameLo.startsWith(q))                          score += 20; // name prefix
  else if (nameLo.includes(q))                            score += 10; // name contains
  if (tool.categories.some((s) =>
    s.toLowerCase() === q || catName(s).toLowerCase() === q)) score += 9; // exact category
  else if (tool.categories.some((s) =>
    s.toLowerCase().includes(q) || catName(s).toLowerCase().includes(q))) score += 7; // partial category
  if (tool.bestFor?.some((b) => b.toLowerCase().includes(q)))  score += 5; // bestFor
  if (tool.overview?.toLowerCase().includes(q))                score += 3; // overview
  if (tool.description.toLowerCase().includes(q))              score += 2; // description
  if (tool.slug.toLowerCase().includes(q))                     score += 1; // slug
  return score;
}

// ├бРђЮРѓг├бРђЮРѓг Category filter state ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
let activeCat = '';

const catCounts = {};
TOOLS.forEach((t) => t.categories.forEach((c) => { catCounts[c] = (catCounts[c] || 0) + 1; }));
const topCats = Object.entries(catCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 14)
  .map(([slug]) => slug);

function renderCatChips() {
  const allActive = !activeCat ? ' cat-chip-active' : '';
  const chips = topCats.map((slug) => {
    const active = slug === activeCat ? ' cat-chip-active' : '';
    return `<button class="cat-chip${active}" data-cat="${slug}">${esc(catName(slug))}</button>`;
  });
  return `<button class="cat-chip${allActive}" data-cat="">All</button>${chips.join('')}`;
}

function initCatChips() {
  const el = document.getElementById('cat-filters');
  el.innerHTML = renderCatChips();
  el.addEventListener('click', (e) => {
    const btn = e.target.closest('.cat-chip');
    if (!btn) return;
    activeCat = btn.dataset.cat || '';
    el.innerHTML = renderCatChips();
    doSearch(document.getElementById('q').value);
  });
}

// ├бРђЮРѓг├бРђЮРѓг Search ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
function doSearch(raw) {
  const q = raw.trim().toLowerCase();
  const countEl = document.getElementById('count');
  const resultsEl = document.getElementById('results');

  if (!q && !activeCat) {
    countEl.textContent = '';
    resultsEl.innerHTML = POPULAR_HTML;
    return;
  }

  let hits;
  if (!q && activeCat) {
    hits = TOOLS.filter((t) => t.categories.includes(activeCat));
  } else {
    hits = TOOLS
      .map((t) => ({ tool: t, score: scoreMatch(t, q) }))
      .filter((x) => x.score > 0 && (!activeCat || x.tool.categories.includes(activeCat)))
      .sort((a, b) => b.score - a.score)
      .map((x) => x.tool);
  }

  const label = activeCat
    ? (q ? `"${raw.trim()}" in ${catName(activeCat)}` : catName(activeCat))
    : `"${raw.trim()}"`;

  countEl.textContent = hits.length
    ? `${hits.length} result${hits.length === 1 ? '' : 's'} for ${label}`
    : `No results for ${label}`;

  resultsEl.innerHTML = hits.length
    ? hits.map((t) => renderCard(t, q)).join('')
    : `<div class="no-results">Try a different keyword or <a href="/category">browse categories</a>.</div>`;

  // GA4 search event (fires after results render, not on every keystroke)
  if (q && typeof gtag === 'function') {
    gtag('event', 'search', {
      search_term: q,
      results_count: hits.length,
      category_filter: activeCat || null,
    });
  }
}

const input = document.getElementById('q');

let timer;
function onInput() {
  const val = input.value;

  const url = new URL(location.href);
  val.trim() ? url.searchParams.set('q', val.trim()) : url.searchParams.delete('q');
  history.replaceState(null, '', url);

  clearTimeout(timer);
  timer = setTimeout(() => doSearch(val), 180);
}

input.addEventListener('input', onInput);
initCatChips();

const init = new URLSearchParams(location.search).get('q') || '';
if (init) { input.value = init; doSearch(init); }
else { doSearch(''); }

// ├бРђЮРѓг├бРђЮРѓг Autocomplete ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
(function() {
  var acDrop = document.getElementById('ac-drop');
  if (!acDrop) return;

  var slimTools = TOOLS.map(function(t) { return [t.name, t.slug, t.rating]; });
  var slimCats = TAXONOMIES.map(function(t) { return [t.name, t.slug]; });

  var acIdx = -1;
  var acItems = [];
  var acTimer;

  function escAc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function markAc(text, q) {
    var s = escAc(text);
    if (!q) return s;
    var re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')', 'gi');
    return s.replace(re, '<mark>$1</mark>');
  }

  function suggestAcTools(q) {
    var ql = q.toLowerCase();
    return slimTools
      .filter(function(t) { return t[0].toLowerCase().includes(ql); })
      .sort(function(a, b) {
        var ap = a[0].toLowerCase().startsWith(ql) ? 1 : 0;
        var bp = b[0].toLowerCase().startsWith(ql) ? 1 : 0;
        return bp - ap || b[2] - a[2];
      })
      .slice(0, 5);
  }

  function suggestAcCats(q) {
    var ql = q.toLowerCase();
    return slimCats.filter(function(c) { return c[0].toLowerCase().includes(ql); }).slice(0, 3);
  }

  function renderAcDrop(q) {
    var tools = suggestAcTools(q);
    var cats = suggestAcCats(q);
    if (!tools.length && !cats.length) { acDrop.hidden = true; return; }

    var html = '';
    if (tools.length) {
      html += '<div class="ac-section"><div class="ac-label">Jump to</div>';
      tools.forEach(function(t) {
        html += '<div class="ac-item" data-href="/reviews/' + escAc(t[1]) + '" role="option" tabindex="-1">' +
          '<span class="ac-name">' + markAc(t[0], q) + '</span>' +
          '<span class="ac-rating">&#9733; ' + t[2] + '</span>' +
          '</div>';
      });
      html += '</div>';
    }
    if (cats.length) {
      html += '<div class="ac-section"><div class="ac-label">Categories</div>';
      cats.forEach(function(c) {
        html += '<div class="ac-item" data-href="/category/' + escAc(c[1]) + '" role="option" tabindex="-1">' +
          '<span class="ac-name">' + markAc(c[0], q) + '</span>' +
          '</div>';
      });
      html += '</div>';
    }

    acDrop.innerHTML = html;
    acDrop.hidden = false;
    acIdx = -1;
    acItems = Array.from(acDrop.querySelectorAll('.ac-item'));
    acItems.forEach(function(item) {
      item.addEventListener('mouseenter', function() {
        acIdx = acItems.indexOf(item);
        updateAcSel();
      });
      item.addEventListener('click', function() {
        location.href = item.dataset.href;
      });
    });
  }

  function closeAcDrop() {
    acDrop.hidden = true;
    acIdx = -1;
    acItems = [];
  }

  function updateAcSel() {
    acItems.forEach(function(item, i) {
      item.classList.toggle('ac-item-active', i === acIdx);
    });
  }

  input.addEventListener('input', function() {
    clearTimeout(acTimer);
    acTimer = setTimeout(function() {
      var q = input.value.trim();
      if (q.length < 1) { closeAcDrop(); return; }
      renderAcDrop(q);
    }, 80);
  });

  input.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeAcDrop(); return; }
    if (!acItems.length) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      acIdx = Math.min(acIdx + 1, acItems.length - 1);
      updateAcSel();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      acIdx = Math.max(acIdx - 1, -1);
      updateAcSel();
    } else if (e.key === 'Enter' && acIdx >= 0 && acItems[acIdx]) {
      e.preventDefault();
      location.href = acItems[acIdx].dataset.href;
    }
  });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.search-box')) closeAcDrop();
  });
})();
</script>

<style>
  .search-hero {
    padding: 48px 0 32px;
    text-align: center;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 40px;
  }
  h1 {
    font-size: 2.25rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 10px;
  }
  .search-sub {
    font-size: 1rem;
    color: #6b7280;
    margin: 0 0 28px;
  }

  /* Search box */
  .search-box {
    position: relative;
    max-width: 600px;
    margin: 0 auto;
  }
  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }
  #q {
    width: 100%;
    padding: 14px 20px 14px 48px;
    font-size: 1rem;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    outline: none;
    font-family: inherit;
    color: #111827;
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  #q:focus {
    border-color: #7C3AED;
    box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
  }
  #q::placeholder { color: #9ca3af; }

  .result-count {
