    .filter-tabs { gap: 6px; }
    .ftab { padding: 6px 12px; font-size: 0.8rem; }
  }
</style>

<script>
  // Intro expand/collapse
  const btn = document.getElementById('introToggle') as HTMLButtonElement | null;
  const inner = document.querySelector('.intro-inner');
  const label = btn?.querySelector('span');
  if (btn && inner && label) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      inner.classList.toggle('expanded', !expanded);
      label.textContent = expanded ? 'Read more' : 'Show less';
    });
  }

  // Pricing filter tabs
  const tabs = document.querySelectorAll<HTMLButtonElement>('.ftab');
  const grid = document.getElementById('toolsGrid');
  const noResults = document.getElementById('noResults');
  const noResultsReset = document.getElementById('noResultsReset');

  function applyFilter(filter: string) {
    tabs.forEach(t => t.classList.remove('ftab-active'));
    const activeTab = Array.from(tabs).find(t => t.dataset.filter === filter);
    if (activeTab) activeTab.classList.add('ftab-active');

    if (!grid) return;
    const cards = grid.querySelectorAll<HTMLElement>('[data-pricing]');
    let visible = 0;
    cards.forEach(card => {
      const pricing = card.dataset.pricing ?? '';
      let show = false;
      if (filter === 'all') {
        show = true;
      } else if (filter === 'freemium') {
        show = pricing === 'free' || pricing === 'freemium';
      } else {
        show = pricing === filter;
      }
      card.hidden = !show;
      if (show) visible++;
    });
    if (noResults) noResults.hidden = visible > 0;
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => applyFilter(tab.dataset.filter ?? 'all'));
  });

  if (noResultsReset) {
    noResultsReset.addEventListener('click', () => applyFilter('all'));
  }
</script>
