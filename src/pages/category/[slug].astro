---
import tools from "../../data/generated/tools-enriched.json";
import taxonomies from "../../data/taxonomies.json";
import categoryContent from "../../data/category-content.json";
import MainLayout from "../../layouts/MainLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import ToolLogo from "../../components/ToolLogo.astro";

export async function getStaticPaths() {
  return taxonomies.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const categoryTools = tools.filter((t) => t.categories.includes(category.slug));

// Top Rated: highest rating, max 3
const topRated = [...categoryTools].sort((a, b) => b.rating - a.rating).slice(0, 3);
const topSlugs = new Set(topRated.map((t) => t.slug));

// Remaining tools (not in top-rated), sorted by rating desc
const allRemainingTools = categoryTools
  .filter((t) => !topSlugs.has(t.slug))
  .sort((a, b) => b.rating - a.rating);

// Hero stats
const avgRating = categoryTools.length
  ? (categoryTools.reduce((s, t) => s + t.rating, 0) / categoryTools.length).toFixed(1)
  : "—";
const freemiumCount = categoryTools.filter((t) => t.pricing === "Free" || t.pricing === "Freemium").length;
const paidCount = categoryTools.filter((t) => t.pricing === "Paid").length;

// Related categories: all 10 others, sorted by tool count descending
const relatedCategories = taxonomies
  .filter((c) => c.slug !== category.slug)
  .map((c) => ({
    ...c,
    toolCount: tools.filter((t) => t.categories.includes(c.slug)).length,
  }))
  .sort((a, b) => b.toolCount - a.toolCount);

// SEO content from category-content.json
const catContent = (categoryContent as any[]).find((c: any) => c.category === category.slug) ?? null;

// Convert intro paragraphs to HTML <p> tags
const introHtml: string | null = catContent?.intro
  ? catContent.intro
      .split('\n\n')
      .map((p: string) => `<p>${p.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>`)
      .join('')
  : null;

// FAQ JSON-LD (FAQPage schema)
const faqJsonLdStr: string | null = catContent?.faqs?.length
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: catContent.faqs.map(({ question, answer }: { question: string; answer: string }) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    })
  : null;

// JSON-LD: CollectionPage + BreadcrumbList + ItemList
const SITE      = "https://zotopie.com";
const pageUrl   = `${SITE}/category/${category.slug}/`;
const pageTitle = `Best ${category.name} Tools | Zotopie`;
const pageDesc  = `Discover the best ${category.name} tools. Expert reviews of ${categoryTools.length} tools — ${category.description}`;

const catJsonLdStr = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: pageTitle,
      description: pageDesc,
      breadcrumb: { "@id": `${pageUrl}#breadcrumb` },
      publisher: { "@type": "Organization", name: "Zotopie", url: SITE },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home",       item: `${SITE}/` },
        { "@type": "ListItem", position: 2, name: "Categories", item: `${SITE}/category/` },
        { "@type": "ListItem", position: 3, name: category.name },
      ],
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#itemlist`,
      name: `Best ${category.name} Tools`,
      numberOfItems: categoryTools.length,
      itemListElement: categoryTools
        .sort((a, b) => b.rating - a.rating)
        .map((t, i) => ({
          "@type": "ListItem",
          position: i + 1,
          item: {
            "@type": "SoftwareApplication",
            name: t.name,
            url: `${SITE}/reviews/${t.slug}/`,
            applicationCategory: "WebApplication",
            aggregateRating: {
              "@type": "AggregateRating",
              ratingValue: t.rating,
              bestRating: 5,
              worstRating: 1,
              ratingCount: 1,
            },
          },
        })),
    },
  ],
});
---

<MainLayout
  title={pageTitle}
  description={pageDesc}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={catJsonLdStr} />
    {faqJsonLdStr && <script type="application/ld+json" set:html={faqJsonLdStr} />}
  </Fragment>

  <!-- HERO -->
  <section class="cat-hero">
    <div class="breadcrumb">
      <a href="/">Home</a> &rsaquo;
      <a href="/category">Categories</a> &rsaquo;
      <span>{category.name}</span>
    </div>
    <h1>{category.name}</h1>
    <p class="cat-desc">{category.description}</p>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">{categoryTools.length}</span>
        <span class="stat-label">Tools Reviewed</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-value">★ {avgRating}</span>
        <span class="stat-label">Avg Rating</span>
      </div>
      {freemiumCount > 0 && (
        <>
          <div class="stat-div"></div>
          <div class="stat">
            <span class="stat-value">{freemiumCount}</span>
            <span class="stat-label">Free / Freemium</span>
          </div>
        </>
      )}
      {paidCount > 0 && (
        <>
          <div class="stat-div"></div>
          <div class="stat">
            <span class="stat-value">{paidCount}</span>
            <span class="stat-label">Paid Only</span>
          </div>
        </>
      )}
    </div>
  </section>

  <!-- INTRO (from category-content.json) -->
  {introHtml && (
    <section class="cat-intro">
      <div class="intro-inner" set:html={introHtml} />
      <button class="intro-toggle" id="introToggle" aria-expanded="false">
        <span>Read more</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </section>
  )}

  <!-- TOP RATED -->
  {topRated.length > 0 && (
    <section class="cat-section">
      <div class="section-hd">
        <div>
          <h2>Top Rated {category.name} Tools</h2>
          <p class="section-sub">Ranked by our editorial score</p>
        </div>
      </div>
      <div class="ranked-list">
        {topRated.map((tool, i) => (
          <a href={`/reviews/${tool.slug}`} class="ranked-card">
            <span class={`rank rank-${i + 1}`}>#{i + 1}</span>
            <div class="rc-logo">
              <ToolLogo tool={tool} size={44} />
            </div>
            <div class="rc-body">
              <div class="rc-header">
                <span class="rc-name">{tool.name}</span>
                {tool.featured && <span class="rc-badge">Featured</span>}
              </div>
              <p class="rc-desc">{tool.description}</p>
              <span class="rc-price">
                {tool.startingPrice ? `from ${tool.startingPrice}` : tool.pricing}
              </span>
            </div>
            <div class="rc-right">
              <span class="rc-rating">★ {tool.rating}</span>
              <span class="rc-cta">Read Review →</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- MORE TOOLS (all category tools minus top-rated, with pricing filter) -->
  {allRemainingTools.length > 0 && (
    <section class="cat-section">
      <div class="section-hd">
        <div>
          <h2>More {category.name} Tools</h2>
          <p class="section-sub">All reviewed tools, sorted by rating</p>
        </div>
        <span class="tool-count-badge">{allRemainingTools.length} tools</span>
      </div>

      {(freemiumCount > 0 && paidCount > 0) && (
        <div class="filter-tabs" role="group" aria-label="Filter by pricing">
          <button class="ftab ftab-active" data-filter="all">
            All <span class="ftab-count">{allRemainingTools.length}</span>
          </button>
          <button class="ftab" data-filter="freemium">
            Free / Freemium
            <span class="ftab-count">{allRemainingTools.filter(t => t.pricing === 'Free' || t.pricing === 'Freemium').length}</span>
          </button>
          <button class="ftab" data-filter="paid">
            Paid
            <span class="ftab-count">{allRemainingTools.filter(t => t.pricing === 'Paid').length}</span>
          </button>
        </div>
      )}

      <div class="tools-grid" id="toolsGrid">
        {allRemainingTools.map((tool) => (
          <div data-pricing={tool.pricing.toLowerCase()}>
            <ToolCard tool={tool} />
          </div>
        ))}
      </div>

      <div class="no-results" id="noResults" hidden>
        <p>No tools match this filter. <button class="no-results-reset" id="noResultsReset">Show all</button></p>
      </div>
    </section>
  )}

  <!-- EMPTY STATE -->
  {categoryTools.length === 0 && (
    <section class="empty-state">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
      </svg>
      <p>No tools reviewed in this category yet.</p>
      <a href="/reviews" class="empty-link">Browse all reviews &rarr;</a>
    </section>
  )}

  <!-- HOW TO CHOOSE (from category-content.json only) -->
  {catContent?.how_to_choose?.length > 0 && (
    <section class="cat-section htc-section">
      <div class="section-hd">
        <div>
          <h2>How to Choose the Best {category.name} Tool</h2>
          <p class="section-sub">Key factors to evaluate before you decide</p>
        </div>
      </div>
      <ol class="htc-list">
        {(catContent.how_to_choose as string[]).map((item, i) => (
          <li class="htc-item">
            <span class="htc-num">{i + 1}</span>
            <span class="htc-text">{item}</span>
          </li>
        ))}
      </ol>
    </section>
  )}

  <!-- FAQ (from category-content.json) -->
  {catContent?.faqs?.length > 0 && (
    <section class="cat-section faq-section">
      <div class="section-hd">
        <div>
          <h2>Frequently Asked Questions</h2>
          <p class="section-sub">{category.name} software — common questions answered</p>
        </div>
      </div>
      <div class="faq-list">
        {(catContent.faqs as {question: string; answer: string}[]).map(({ question, answer }) => (
          <details class="faq-item">
            <summary class="faq-q">
              <span>{question}</span>
              <svg class="faq-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-a">{answer}</div>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- RELATED CATEGORIES -->
  <section class="related-section">
    <div class="section-hd">
      <h2>Explore Other Categories</h2>
    </div>
    <div class="related-grid">
      {relatedCategories.map((cat) => (
        <a href={`/category/${cat.slug}`} class="related-card">
          <div class="related-card-top">
            <span class="related-name">{cat.name}</span>
            <span class="related-count">{cat.toolCount}</span>
          </div>
          <p class="related-desc">{cat.description}</p>
        </a>
      ))}
    </div>
  </section>

</MainLayout>

<style>
  /* HERO */
  .cat-hero {
    padding: 48px 0 36px;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 40px;
    position: relative;
  }
  .cat-hero::before {
    content: "";
    position: absolute;
    top: 0; left: -24px; right: -24px;
    height: 3px;
    background: linear-gradient(90deg, #7C3AED, #6366F1);
  }
  .breadcrumb {
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 18px;
  }
  .breadcrumb a { color: #647488; }
  .breadcrumb a:hover { color: #7C3AED; text-decoration: none; }
  h1 {
    font-size: 2.25rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 10px;
    letter-spacing: -0.02em;
  }
  .cat-desc {
    font-size: 1rem;
    color: #6b7280;
    margin: 0 0 28px;
    max-width: 640px;
    line-height: 1.7;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 16px 24px;
    width: fit-content;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 0 20px;
  }
  .stat:first-child { padding-left: 0; }
  .stat-value {
    font-size: 1.4rem;
    font-weight: 800;
    color: #111827;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.72rem;
    color: #9ca3af;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .stat-div {
    width: 1px;
    height: 36px;
    background: #e5e7eb;
    flex-shrink: 0;
  }

  /* SECTION COMMON */
  .cat-section {
    padding: 44px 0;
    border-top: 1px solid #f3f4f6;
  }
  .section-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .section-hd h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 3px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-hd h2::before {
    content: "";
    display: inline-block;
    width: 4px;
    height: 1.1em;
    background: linear-gradient(180deg, #7C3AED, #6366F1);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .section-sub {
    font-size: 0.875rem;
    color: #9ca3af;
    margin: 0;
  }
  .tool-count-badge {
    font-size: 0.8rem;
    font-weight: 600;
    background: #F5F3FF;
    color: #7C3AED;
    border: 1px solid #DDD6FE;
    padding: 4px 12px;
    border-radius: 20px;
    flex-shrink: 0;
  }

  /* TOP RATED ranked list */
  .ranked-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ranked-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 22px;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s, box-shadow 0.18s, background 0.18s, transform 0.15s;
    position: relative;
  }
  .ranked-card:first-child {
    border-color: #fde68a;
    background: linear-gradient(to right, #fffbeb, #fff);
  }
  .ranked-card:hover {
    border-color: #C4B5FD;
    box-shadow: 0 4px 16px rgba(124,58,237,0.12);
    background: #FDFAFF;
    text-decoration: none;
    transform: translateY(-1px);
  }
  .ranked-card:first-child:hover {
    border-color: #f59e0b;
    box-shadow: 0 4px 16px rgba(245,158,11,0.15);
  }
  .rank {
    font-size: 1.1rem;
    font-weight: 800;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    flex-shrink: 0;
    color: #6b7280;
    background: #f3f4f6;
  }
  .rank-1 {
    color: #92400e;
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    font-size: 1rem;
  }
  .rank-2 { color: #6b7280; background: #f3f4f6; }
  .rank-3 { color: #9a3412; background: #fed7aa; }
  .rc-logo { flex-shrink: 0; }
  .rc-body { flex: 1; min-width: 0; }
  .rc-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }
  .rc-name { font-size: 1rem; font-weight: 700; color: #111827; }
  .rc-badge {
    font-size: 0.68rem;
    font-weight: 700;
    background: #F5F3FF;
    color: #7C3AED;
    border: 1px solid #DDD6FE;
    padding: 2px 7px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .rc-desc {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0 0 5px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rc-price {
    font-size: 0.75rem;
    color: #9ca3af;
    font-weight: 600;
    background: #f3f4f6;
    padding: 1px 8px;
    border-radius: 8px;
    display: inline-block;
  }
  .rc-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 7px;
    flex-shrink: 0;
  }
  .rc-rating {
    font-size: 0.85rem;
    font-weight: 700;
    color: #92400e;
    background: #fef3c7;
    border: 1px solid #fde68a;
    padding: 3px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .rc-cta {
    font-size: 0.78rem;
    font-weight: 700;
    color: #7C3AED;
    background: #F5F3FF;
    border: 1px solid #DDD6FE;
    padding: 4px 12px;
    border-radius: 20px;
  }

  /* PRICING FILTER TABS */
  .filter-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: 24px;
    flex-wrap: wrap;
    background: #f3f4f6;
    padding: 4px;
    border-radius: 12px;
    width: fit-content;
  }
  .ftab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 18px;
    border: none;
    border-radius: 9px;
    background: transparent;
    font-size: 0.85rem;
    font-weight: 600;
    color: #6b7280;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s, box-shadow 0.15s;
  }
  .ftab:hover {
    color: #374151;
    background: #fff;
  }
  .ftab-active {
    background: #fff;
    color: #111827;
    box-shadow: 0 1px 4px rgba(0,0,0,0.10), 0 0 0 1px rgba(0,0,0,0.04);
  }
  .ftab-count {
    font-size: 0.72rem;
    font-weight: 700;
    background: #e5e7eb;
    color: #9ca3af;
    padding: 1px 6px;
    border-radius: 8px;
  }
  .ftab-active .ftab-count {
    background: #EDE9FE;
    color: #7C3AED;
  }

  /* TOOLS GRID */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .tools-grid > [data-pricing][hidden] { display: none; }

  /* NO RESULTS */
  .no-results {
    padding: 24px;
    text-align: center;
    color: #6b7280;
    font-size: 0.9rem;
  }
  .no-results-reset {
    background: none;
    border: none;
    color: #7C3AED;
    font-weight: 600;
    cursor: pointer;
    font-size: inherit;
    font-family: inherit;
    padding: 0;
    text-decoration: underline;
  }

  /* EMPTY */
  .empty-state {
    padding: 64px 0;
    text-align: center;
    color: #6b7280;
  }
  .empty-state svg { margin-bottom: 16px; }
  .empty-state p { font-size: 1rem; margin-bottom: 16px; }
  .empty-link { font-size: 0.95rem; font-weight: 600; color: #7C3AED; }

  /* RELATED CATEGORIES */
  .related-section {
    border-top: 1px solid #e5e7eb;
    padding: 40px 0 24px;
  }
  .related-section .section-hd {
    margin-bottom: 16px;
  }
  .related-section .section-hd h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin: 0;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 14px 16px;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .related-card:hover {
    border-color: #C4B5FD;
    box-shadow: 0 2px 10px rgba(124,58,237,0.10);
    text-decoration: none;
  }
  .related-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .related-name { font-size: 0.9rem; font-weight: 700; color: #111827; }
  .related-count {
    font-size: 0.72rem;
    font-weight: 600;
    background: #f3f4f6;
    color: #9ca3af;
    padding: 2px 7px;
    border-radius: 10px;
    flex-shrink: 0;
  }
  .related-desc {
    font-size: 0.78rem;
    color: #9ca3af;
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* INTRO */
  .cat-intro {
    padding: 32px 0 8px;
    border-bottom: 1px solid #e5e7eb;
  }
  .intro-inner {
    max-height: 6.4em;
    overflow: hidden;
    transition: max-height 0.35s ease;
    position: relative;
  }
  .intro-inner.expanded { max-height: 9999px; }
  .intro-inner :global(p) {
    font-size: 0.95rem;
    line-height: 1.75;
    color: #4b5563;
    margin: 0 0 1em;
  }
  .intro-inner :global(p:last-child) { margin-bottom: 0; }
  .intro-inner:not(.expanded)::after {
    content: "";
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 40px;
    background: linear-gradient(transparent, #f9fafb);
    pointer-events: none;
  }
  .intro-toggle {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 10px;
    margin-bottom: 8px;
    background: none;
    border: none;
    font-size: 0.875rem;
    font-weight: 600;
    color: #7C3AED;
    cursor: pointer;
    padding: 0;
    font-family: inherit;
    transition: color 0.15s;
  }
  .intro-toggle:hover { color: #6D28D9; }
  .intro-toggle svg { transition: transform 0.25s; }
  .intro-toggle[aria-expanded="true"] svg { transform: rotate(180deg); }

  /* HOW TO CHOOSE */
  .htc-section { border-top: 1px solid #e5e7eb; }
  .htc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .htc-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 18px;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
  }
  .htc-num {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
    border-radius: 50%;
    background: #7C3AED;
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .htc-text { font-size: 0.9rem; color: #374151; line-height: 1.55; }

  /* FAQ */
  .faq-section { border-top: 1px solid #e5e7eb; }
  .faq-list { display: flex; flex-direction: column; gap: 8px; }
  .faq-item {
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    transition: border-color 0.15s;
  }
  .faq-item[open] { border-color: #DDD6FE; }
  .faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 16px 18px;
    font-size: 0.95rem;
    font-weight: 600;
    color: #111827;
    cursor: pointer;
    list-style: none;
    user-select: none;
    background: #f9fafb;
    transition: background 0.15s;
  }
  .faq-item[open] .faq-q { background: #F5F3FF; color: #7C3AED; }
  .faq-q::-webkit-details-marker { display: none; }
