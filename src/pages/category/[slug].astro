    .tools-grid { grid-template-columns: 1fr; }
    .related-grid { grid-template-columns: 1fr; }
    .rc-cta { display: none; }
    .hero-stats { gap: 16px; }
    .stat-div { display: none; }
    .stat { padding: 0; }
    .htc-item { padding: 12px 14px; }
    .faq-q { padding: 14px 14px; font-size: 0.9rem; }
