<script>
  // Intro expand/collapse
  const btn = document.getElementById('introToggle');
  const inner = document.querySelector('.intro-inner');
  if (btn && inner) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      inner.classList.toggle('expanded', !expanded);
      btn.querySelector('span') && (btn.querySelector('span')!.textContent = expanded ? 'Read more' : 'Show less');
    });
  }
</script>
