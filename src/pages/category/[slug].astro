---
import tools from "../../data/generated/tools-enriched.json";
import taxonomies from "../../data/taxonomies.json";
import categoryContent from "../../data/category-content.json";
import MainLayout from "../../layouts/MainLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import ToolLogo from "../../components/ToolLogo.astro";

export async function getStaticPaths() {
  return taxonomies.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const categoryTools = tools.filter((t) => t.categories.includes(category.slug));

// Top Rated: highest rating, max 3
const topRated = [...categoryTools].sort((a, b) => b.rating - a.rating).slice(0, 3);
const topSlugs = new Set(topRated.map((t) => t.slug));

// Featured: featured flag, excl. top-rated, max 3
const featuredTools = categoryTools
  .filter((t) => t.featured && !topSlugs.has(t.slug))
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 3);
const featuredSlugs = new Set(featuredTools.map((t) => t.slug));

// Newest: by addedDate desc, excl. top-rated + featured, max 3
const newestTools = [...categoryTools]
  .filter((t) => !topSlugs.has(t.slug) && !featuredSlugs.has(t.slug))
  .sort((a, b) => b.addedDate.localeCompare(a.addedDate))
  .slice(0, 3);

// Hero stats
const avgRating = categoryTools.length
  ? (categoryTools.reduce((s, t) => s + t.rating, 0) / categoryTools.length).toFixed(1)
  : "—";
const freeCount = categoryTools.filter((t) => t.pricing === "Free" || t.pricing === "Freemium").length;

const relatedCategories = taxonomies.filter((c) => c.slug !== category.slug).slice(0, 6);

// SEO content from category-content.json
const catContent = (categoryContent as any[]).find((c: any) => c.category === category.slug) ?? null;

// Convert intro paragraphs (split on double newline) to HTML <p> tags
const introHtml: string | null = catContent?.intro
  ? catContent.intro
      .split('\n\n')
      .map((p: string) => `<p>${p.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p>`)
      .join('')
  : null;

// FAQ JSON-LD (FAQPage schema)
const faqJsonLdStr: string | null = catContent?.faqs?.length
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: catContent.faqs.map(({ question, answer }: { question: string; answer: string }) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    })
  : null;

// JSON-LD: CollectionPage + BreadcrumbList + ItemList
const SITE      = "https://zotopie.com";
const pageUrl   = `${SITE}/category/${category.slug}/`;
const pageTitle = `Best ${category.name} Tools | Zotopie`;
const pageDesc  = `Discover the best ${category.name} tools. ${category.description}`;

const catJsonLdStr = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: pageTitle,
      description: pageDesc,
      breadcrumb: { "@id": `${pageUrl}#breadcrumb` },
      publisher: { "@type": "Organization", name: "Zotopie", url: SITE },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home",       item: `${SITE}/` },
        { "@type": "ListItem", position: 2, name: "Categories", item: `${SITE}/category/` },
        { "@type": "ListItem", position: 3, name: category.name },
      ],
    },
    {
      "@type": "ItemList",
      "@id": `${pageUrl}#itemlist`,
      name: `Best ${category.name} Tools`,
      numberOfItems: categoryTools.length,
      itemListElement: categoryTools
        .sort((a, b) => b.rating - a.rating)
        .map((t, i) => ({
          "@type": "ListItem",
          position: i + 1,
          item: {
            "@type": "SoftwareApplication",
            name: t.name,
            url: `${SITE}/reviews/${t.slug}/`,
            applicationCategory: "WebApplication",
            aggregateRating: {
              "@type": "AggregateRating",
              ratingValue: t.rating,
              bestRating: 5,
              worstRating: 1,
              ratingCount: 1,
            },
          },
        })),
    },
  ],
});
---

<MainLayout
  title={pageTitle}
  description={pageDesc}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={catJsonLdStr} />
    {faqJsonLdStr && <script type="application/ld+json" set:html={faqJsonLdStr} />}
  </Fragment>

  <!-- HERO -->
  <section class="cat-hero">
    <div class="breadcrumb">
      <a href="/">Home</a> &rsaquo;
      <a href="/category">Categories</a> &rsaquo;
      <span>{category.name}</span>
    </div>
    <h1>{category.name}</h1>
    <p class="cat-desc">{category.description}</p>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">{categoryTools.length}</span>
        <span class="stat-label">Tools Reviewed</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat">
        <span class="stat-value">★ {avgRating}</span>
        <span class="stat-label">Avg Rating</span>
      </div>
      {freeCount > 0 && (
        <>
          <div class="stat-div"></div>
          <div class="stat">
            <span class="stat-value">{freeCount}</span>
            <span class="stat-label">Free / Freemium</span>
          </div>
        </>
      )}
    </div>
  </section>

  <!-- INTRO (from category-content.json) -->
  {introHtml && (
    <section class="cat-intro">
      <div class="intro-inner" set:html={introHtml} />
      <button class="intro-toggle" id="introToggle" aria-expanded="false">
        Read more <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </section>
  )}

  <!-- TOP RATED -->
  {topRated.length > 0 && (
    <section class="cat-section">
      <div class="section-hd">
        <div>
          <h2>Top Rated {category.name} Tools</h2>
          <p class="section-sub">Ranked by our editorial score</p>
        </div>
      </div>
      <div class="ranked-list">
        {topRated.map((tool, i) => (
          <a href={`/reviews/${tool.slug}`} class="ranked-card">
            <span class={`rank rank-${i + 1}`}>#{i + 1}</span>
            <div class="rc-logo">
              <ToolLogo tool={tool} size={44} />
            </div>
            <div class="rc-body">
              <div class="rc-header">
                <span class="rc-name">{tool.name}</span>
                {tool.featured && <span class="rc-badge">Featured</span>}
              </div>
              <p class="rc-desc">{tool.description}</p>
              <span class="rc-price">
                {tool.startingPrice ? `from ${tool.startingPrice}` : tool.pricing}
              </span>
            </div>
            <div class="rc-right">
              <span class="rc-rating">★ {tool.rating}</span>
              <span class="rc-cta">Read Review →</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- FEATURED (editor's picks not in top-rated) -->
  {featuredTools.length > 0 && (
    <section class="cat-section">
      <div class="section-hd">
        <div>
          <h2>Editor's Picks</h2>
          <p class="section-sub">Hand-selected tools worth trying</p>
        </div>
      </div>
      <div class="tools-grid">
        {featuredTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  )}

  <!-- NEWEST -->
  {newestTools.length > 0 && (
    <section class="cat-section">
      <div class="section-hd">
        <div>
          <h2>Recently Added</h2>
          <p class="section-sub">Freshly reviewed tools in this category</p>
        </div>
      </div>
      <div class="tools-grid">
        {newestTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  )}

  <!-- ALL TOOLS -->
  {categoryTools.length > 0 ? (
    <section class="cat-section">
      <div class="section-hd">
        <h2>All {category.name} Tools</h2>
        <span class="tool-count-badge">{categoryTools.length} tools</span>
      </div>
      <div class="tools-grid">
        {categoryTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  ) : (
    <section class="empty-state">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
      </svg>
      <p>No tools reviewed in this category yet.</p>
      <a href="/reviews" class="empty-link">Browse all reviews &rarr;</a>
    </section>
  )}

  <!-- BUYING GUIDE -->
  {categoryTools.length > 0 && (() => {
    const sortedByPrice = [...categoryTools]
      .filter((t) => t.startingPrice)
      .sort((a, b) => {
        const pa = parseFloat(a.startingPrice?.match(/[\d.]+/)?.[0] ?? "999999");
        const pb = parseFloat(b.startingPrice?.match(/[\d.]+/)?.[0] ?? "999999");
        return pa - pb;
      });
    const cheapest   = sortedByPrice[0];
    const mostFull   = [...categoryTools].sort((a, b) => b.rating - a.rating)[0];
    const freeOpts   = categoryTools.filter((t) => t.pricing === "Free" || t.pricing === "Freemium");
    const paidOpts   = categoryTools.filter((t) => t.pricing === "Paid");
    const priceRange = sortedByPrice.length >= 2
      ? `${sortedByPrice[0].startingPrice} – ${sortedByPrice[sortedByPrice.length - 1].startingPrice}`
      : sortedByPrice[0]?.startingPrice ?? null;
    return (
      <section class="cat-section buying-guide">
        <div class="section-hd">
          <div>
            <h2>How to Choose the Right {category.name} Tool</h2>
            <p class="section-sub">A quick buying guide for {new Date().getFullYear()}</p>
          </div>
        </div>
        <div class="guide-grid">
          <div class="guide-body">
            <p class="guide-intro">
              With {categoryTools.length} tools reviewed in this category, choosing the right one can be tough.
              Here's what to look for when evaluating {category.name} software.
            </p>
            <div class="checklist">
              <div class="cl-item">
                <span class="cl-icon">💰</span>
                <div>
                  <strong>Budget</strong>
                  <p>{freeOpts.length > 0
                    ? `${freeOpts.length} free or freemium option${freeOpts.length !== 1 ? "s" : ""} available.`
                    : "All tools in this category are paid."
                  } {priceRange ? `Paid plans range from ${priceRange}.` : ""}</p>
                </div>
              </div>
              <div class="cl-item">
                <span class="cl-icon">⭐</span>
                <div>
                  <strong>Top-rated pick</strong>
                  <p>Our highest-rated option is <a href={`/reviews/${mostFull.slug}`}>{mostFull.name}</a> (★ {mostFull.rating}/5) — best for those who want the most trusted tool.</p>
                </div>
              </div>
              {cheapest && cheapest.slug !== mostFull.slug && (
                <div class="cl-item">
                  <span class="cl-icon">🏷️</span>
                  <div>
                    <strong>Best value</strong>
                    <p><a href={`/reviews/${cheapest.slug}`}>{cheapest.name}</a> starts at {cheapest.startingPrice} — the most affordable paid option reviewed.</p>
                  </div>
                </div>
              )}
              {freeOpts.length > 0 && (
                <div class="cl-item">
                  <span class="cl-icon">🆓</span>
                  <div>
                    <strong>Free options</strong>
                    <p>{freeOpts.slice(0, 3).map((t, i) => (
                      <><a href={`/reviews/${t.slug}`}>{t.name}</a>{i < Math.min(freeOpts.length, 3) - 1 ? ", " : ""}</>
                    ))}{freeOpts.length > 3 ? ` and ${freeOpts.length - 3} more` : ""} — start for free and upgrade when ready.</p>
                  </div>
                </div>
              )}
              <div class="cl-item">
                <span class="cl-icon">🔗</span>
                <div>
                  <strong>Integrations</strong>
                  <p>Check whether the tool connects with your existing stack (CRM, email, analytics) before committing.</p>
                </div>
              </div>
              <div class="cl-item">
                <span class="cl-icon">📈</span>
                <div>
                  <strong>Scalability</strong>
                  <p>Consider how pricing scales with usage. Some tools charge per seat, others per usage volume — model your expected growth.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="guide-sidebar">
            <div class="guide-summary-card">
              <div class="gsc-title">Quick Stats</div>
              <div class="gsc-row">
                <span class="gsc-label">Tools reviewed</span>
                <span class="gsc-val">{categoryTools.length}</span>
              </div>
              <div class="gsc-row">
                <span class="gsc-label">Avg rating</span>
                <span class="gsc-val">★ {avgRating}</span>
              </div>
              <div class="gsc-row">
                <span class="gsc-label">Free options</span>
                <span class="gsc-val">{freeOpts.length}</span>
              </div>
              <div class="gsc-row">
                <span class="gsc-label">Paid only</span>
                <span class="gsc-val">{paidOpts.length}</span>
              </div>
              {priceRange && (
                <div class="gsc-row">
                  <span class="gsc-label">Price range</span>
                  <span class="gsc-val gsc-price">{priceRange}</span>
                </div>
              )}
              <a href={`/reviews/${mostFull.slug}`} class="gsc-cta">
                See top pick: {mostFull.name} →
              </a>
            </div>
          </div>
        </div>
      </section>
    );
  })()}

  <!-- HOW TO CHOOSE (from category-content.json) -->
  {catContent?.how_to_choose?.length > 0 && (
    <section class="cat-section htc-section">
      <div class="section-hd">
        <div>
          <h2>How to Choose the Best {category.name} Tool</h2>
          <p class="section-sub">Key factors to evaluate before you decide</p>
        </div>
      </div>
      <ol class="htc-list">
        {(catContent.how_to_choose as string[]).map((item, i) => (
          <li class="htc-item">
            <span class="htc-num">{i + 1}</span>
            <span class="htc-text">{item}</span>
          </li>
        ))}
      </ol>
    </section>
  )}

  <!-- FAQ (from category-content.json) -->
  {catContent?.faqs?.length > 0 && (
    <section class="cat-section faq-section">
      <div class="section-hd">
        <div>
          <h2>Frequently Asked Questions</h2>
          <p class="section-sub">{category.name} software — common questions answered</p>
        </div>
      </div>
      <div class="faq-list">
        {(catContent.faqs as {question: string; answer: string}[]).map(({ question, answer }) => (
          <details class="faq-item">
            <summary class="faq-q">
              <span>{question}</span>
              <svg class="faq-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-a">{answer}</div>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- RELATED CATEGORIES -->
  <section class="related-section">
    <h2>Explore Other Categories</h2>
    <div class="related-grid">
      {relatedCategories.map((cat) => {
        const count = tools.filter((t) => t.categories.includes(cat.slug)).length;
        return (
          <a href={`/category/${cat.slug}`} class="related-card">
            <span class="related-name">{cat.name}</span>
            <span class="related-count">{count}</span>
          </a>
        );
      })}
    </div>
  </section>

</MainLayout>

<style>
  /* HERO */
  .cat-hero {
    padding: 48px 0 32px;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 40px;
  }
  .breadcrumb {
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 18px;
  }
  .breadcrumb a { color: #6b7280; }
  .breadcrumb a:hover { color: #2563eb; text-decoration: none; }
  h1 {
    font-size: 2.25rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 10px;
  }
  .cat-desc {
    font-size: 1.05rem;
    color: #6b7280;
    margin: 0 0 24px;
    max-width: 680px;
    line-height: 1.65;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0 20px;
  }
  .stat:first-child { padding-left: 0; }
  .stat-value {
    font-size: 1.35rem;
    font-weight: 800;
    color: #111827;
    line-height: 1;
  }
  .stat-label {
    font-size: 0.78rem;
    color: #9ca3af;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .stat-div {
    width: 1px;
    height: 32px;
    background: #e5e7eb;
    flex-shrink: 0;
  }

  /* SECTION COMMON */
  .cat-section {
    padding: 40px 0;
    border-top: 1px solid #e5e7eb;
  }
  .section-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .section-hd h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 3px;
  }
  .section-sub {
    font-size: 0.875rem;
    color: #9ca3af;
    margin: 0;
  }
  .tool-count-badge {
    font-size: 0.8rem;
    font-weight: 600;
    background: #eff6ff;
    color: #2563eb;
    padding: 4px 12px;
    border-radius: 20px;
    flex-shrink: 0;
  }

  /* TOP RATED ranked list */
  .ranked-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ranked-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
  }
  .ranked-card:hover {
    border-color: #2563eb;
    box-shadow: 0 2px 14px rgba(37,99,235,0.09);
    background: #fafbff;
    text-decoration: none;
  }
  .rank {
    font-size: 1.15rem;
    font-weight: 800;
    width: 30px;
    text-align: center;
    flex-shrink: 0;
    color: #d1d5db;
  }
  .rank-1 { color: #f59e0b; }
  .rank-2 { color: #9ca3af; }
  .rank-3 { color: #d97706; }
  .rc-logo { flex-shrink: 0; }
  .rc-body {
    flex: 1;
    min-width: 0;
  }
  .rc-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 3px;
  }
  .rc-name {
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
  }
  .rc-badge {
    font-size: 0.7rem;
    font-weight: 700;
    background: #eff6ff;
    color: #2563eb;
    padding: 2px 7px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .rc-desc {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0 0 5px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rc-price {
    font-size: 0.78rem;
    color: #9ca3af;
    font-weight: 500;
  }
  .rc-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
  }
  .rc-rating {
    font-size: 0.875rem;
    font-weight: 700;
    color: #d97706;
    background: #fef3c7;
    padding: 2px 10px;
    border-radius: 10px;
  }
  .rc-cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: #2563eb;
  }

  /* TOOLS GRID */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  /* EMPTY */
  .empty-state {
    padding: 64px 0;
    text-align: center;
    color: #6b7280;
  }
  .empty-state svg { margin-bottom: 16px; }
  .empty-state p { font-size: 1rem; margin-bottom: 16px; }
  .empty-link { font-size: 0.95rem; font-weight: 600; color: #2563eb; }

  /* RELATED */
  .related-section {
    border-top: 1px solid #e5e7eb;
    padding-top: 40px;
    padding-bottom: 16px;
  }
  .related-section h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 16px;
  }
  .related-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .related-card {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .related-card:hover {
    border-color: #2563eb;
    color: #2563eb;
    text-decoration: none;
  }
  .related-name { font-weight: 500; }
  .related-count {
    font-size: 0.75rem;
    font-weight: 600;
    background: #f3f4f6;
    color: #9ca3af;
    padding: 1px 7px;
    border-radius: 10px;
  }

  /* BUYING GUIDE */
  .buying-guide { border-top: 2px solid #e5e7eb; padding-top: 40px; }
  .guide-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 32px;
    align-items: start;
  }
  .guide-intro {
    font-size: 0.95rem;
    color: #6b7280;
    margin: 0 0 20px;
    line-height: 1.6;
  }
  .checklist { display: flex; flex-direction: column; gap: 14px; }
  .cl-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px 16px;
    background: #f9fafb;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
  }
  .cl-icon { font-size: 1.2rem; flex-shrink: 0; }
