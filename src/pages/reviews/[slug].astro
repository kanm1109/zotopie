---
import tools from "../../data/generated/tools-enriched.json";
import taxonomies from "../../data/taxonomies.json";
import bestPages from "../../data/best-pages.json";
import MainLayout from "../../layouts/MainLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import ToolLogo from "../../components/ToolLogo.astro";
import AltCard from "../../components/AltCard.astro";

export async function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;

const primaryCategory = taxonomies.find((c) => c.slug === tool.primaryCategory);
const allCategories = taxonomies.filter((c) => tool.categories.includes(c.slug));

// Alternatives: defined list first, fallback to top-rated same-category
let alternativeTools = tools.filter((t) => tool.alternatives.includes(t.slug)).slice(0, 4);
if (alternativeTools.length === 0) {
  alternativeTools = tools
    .filter((t) => t.slug !== tool.slug && t.categories.some((c) => tool.categories.includes(c)))
    .sort((a, b) => b.rating - a.rating)
    .slice(0, 4);
}

// Related Tools: same category, closest rating to current tool; excl. current + alternatives
const altSlugs = new Set(alternativeTools.map((t) => t.slug));
const relatedTools = tools
  .filter((t) =>
    t.slug !== tool.slug &&
    !altSlugs.has(t.slug) &&
    t.categories.some((c) => tool.categories.includes(c))
  )
  .sort((a, b) => Math.abs(a.rating - tool.rating) - Math.abs(b.rating - tool.rating))
  .slice(0, 4);

// Related authority guides: direct match (tool featured in guide) + category match
const relatedGuides = (bestPages as { slug: string; h1: string; categorySlug: string; categoryName: string; toolSlugs: string[] }[]).filter((page) => {
  if (page.toolSlugs.includes(tool.slug)) return true;
  if ((tool.categories as string[]).includes(page.categorySlug)) return true;
  return false;
}).slice(0, 4);

// Previous / Next (by position in dataset)
const toolIndex = tools.findIndex((t) => t.slug === tool.slug);
const prevTool = toolIndex > 0                 ? tools[toolIndex - 1] : null;
const nextTool = toolIndex < tools.length - 1  ? tools[toolIndex + 1] : null;

// Reviewed date: "June 2026" from addedDate "2026-06-10"
const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const [addedYear, addedMonth] = tool.addedDate.split('-');
const reviewDateStr = `${MONTH_NAMES[parseInt(addedMonth) - 1]} ${addedYear}`;

// Auto-generated FAQ from tool data
const autoFaqs: { question: string; answer: string }[] = [];

if (tool.overview) {
  const firstPara = tool.overview.split('\n\n')[0];
  autoFaqs.push({
    question: `What is ${tool.name}?`,
    answer: firstPara.length > 350 ? firstPara.slice(0, 347) + '...' : firstPara,
  });
}

if (tool.pricing === 'Free') {
  autoFaqs.push({
    question: `Is ${tool.name} free?`,
    answer: `Yes, ${tool.name} is free to use.`,
  });
} else if (tool.pricing === 'Freemium') {
  autoFaqs.push({
    question: `Is ${tool.name} free?`,
    answer: `${tool.name} offers a free plan${tool.startingPrice ? `, with paid plans starting at ${tool.startingPrice}` : ''}.`,
  });
} else if (tool.startingPrice) {
  autoFaqs.push({
    question: `How much does ${tool.name} cost?`,
    answer: `${tool.name} pricing starts at ${tool.startingPrice}.`,
  });
}

if (tool.bestFor && tool.bestFor.length > 0) {
  autoFaqs.push({
    question: `Who is ${tool.name} best for?`,
    answer: `${tool.name} is best for: ${(tool.bestFor as string[]).slice(0, 5).join(', ')}.`,
  });
}

if (alternativeTools.length > 0) {
  const altNames = alternativeTools.slice(0, 3).map((t) => t.name);
  const altList = altNames.length > 1
    ? altNames.slice(0, -1).join(', ') + ' and ' + altNames[altNames.length - 1]
    : altNames[0];
  autoFaqs.push({
    question: `What are the best alternatives to ${tool.name}?`,
    answer: `Top alternatives to ${tool.name} include ${altList}.`,
  });
}

// FAQPage JSON-LD for auto-generated FAQs
const faqJsonLdStr = autoFaqs.length > 0
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: autoFaqs.map(({ question, answer }) => ({
        '@type': 'Question',
        name: question,
        acceptedAnswer: { '@type': 'Answer', text: answer },
      })),
    })
  : null;

// Table of Contents: only sections with content
type TocItem = { id: string; label: string };
const toc: TocItem[] = [];
if (tool.overview) toc.push({ id: 'overview', label: 'Overview' });
if ((tool.pros as string[] | undefined)?.length || (tool.cons as string[] | undefined)?.length) toc.push({ id: 'pros-cons', label: 'Pros & Cons' });
if ((tool.bestFor as string[] | undefined)?.length) toc.push({ id: 'best-for', label: 'Best For' });
if ((tool.keyFeatures as unknown[] | undefined)?.length) toc.push({ id: 'key-features', label: 'Key Features' });
if ((tool.useCases as string[] | undefined)?.length) toc.push({ id: 'use-cases', label: 'Use Cases' });
if ((tool.pricingBreakdown as { plans?: unknown[] } | undefined)?.plans?.length) toc.push({ id: 'pricing', label: 'Pricing' });
if ((tool.whoShouldAvoid as string[] | undefined)?.length) toc.push({ id: 'who-should-avoid', label: 'Who to Avoid' });
if (tool.verdict?.summary) toc.push({ id: 'verdict', label: 'Verdict' });
if (alternativeTools.length > 0) toc.push({ id: 'alternatives', label: 'Alternatives' });
if (relatedGuides.length > 0) toc.push({ id: 'guides', label: 'Guides' });
if (autoFaqs.length > 0) toc.push({ id: 'faq', label: 'FAQ' });
if (relatedTools.length > 0) toc.push({ id: 'related', label: 'Related' });

// JSON-LD: WebPage + BreadcrumbList + SoftwareApplication + Review
const SITE    = "https://zotopie.com";
const pageUrl = `${SITE}/reviews/${tool.slug}/`;
const pageTitle = `${tool.name} Review 2026: Pricing, Pros & Cons | Zotopie`;
const pageDesc  = `${tool.name} review 2026: ${tool.description}. Compare pricing, pros, cons, and top alternatives.`;

function parsePrice(raw: string | undefined): string | null {
  if (!raw) return null;
  const m = raw.match(/[\d]+\.?\d*/);
  return m ? m[0] : null;
}

const numericPrice =
  tool.pricing === "Free" || (tool.pricing === "Freemium" && !tool.startingPrice)
    ? "0"
    : parsePrice(tool.startingPrice) ?? null;

const offerNode: Record<string, unknown> = {
  "@type": "Offer",
  priceCurrency: "USD",
  ...(numericPrice !== null ? { price: numericPrice } : {}),
  ...(tool.startingPrice ? { description: tool.startingPrice } : {}),
};

const appCategory = primaryCategory?.name ?? "WebApplication";

const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "Home",    item: `${SITE}/` },
  { "@type": "ListItem", position: 2, name: "Reviews", item: `${SITE}/reviews/` },
  ...(primaryCategory
    ? [
        { "@type": "ListItem", position: 3, name: primaryCategory.name, item: `${SITE}/category/${primaryCategory.slug}/` },
        { "@type": "ListItem", position: 4, name: tool.name },
      ]
    : [{ "@type": "ListItem", position: 3, name: tool.name }]),
];

const jsonLdStr = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: pageTitle,
      description: pageDesc,
      datePublished: tool.addedDate,
      breadcrumb: { "@id": `${pageUrl}#breadcrumb` },
      publisher: { "@type": "Organization", name: "Zotopie", url: SITE },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: breadcrumbItems,
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${pageUrl}#software`,
      name: tool.name,
      url: tool.website,
      applicationCategory: appCategory,
      operatingSystem: "Web, Browser",
      offers: offerNode,
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: tool.rating,
        bestRating: "5",
        worstRating: "1",
        reviewCount: "1",
      },
    },
    {
      "@type": "Review",
      "@id": `${pageUrl}#review`,
      name: `${tool.name} Review 2026`,
      author: { "@type": "Organization", name: "Zotopie", url: SITE },
      datePublished: tool.addedDate,
      reviewBody: tool.overview || tool.description,
      reviewRating: {
        "@type": "Rating",
        ratingValue: String(tool.rating),
        bestRating: "5",
        worstRating: "1",
      },
      itemReviewed: { "@id": `${pageUrl}#software` },
    },
  ],
});
---

<MainLayout
  title={pageTitle}
  description={pageDesc}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLdStr} />
    {faqJsonLdStr && <script type="application/ld+json" set:html={faqJsonLdStr} />}
  </Fragment>

  <!-- BREADCRUMB -->
  <div class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/reviews">Reviews</a> &rsaquo;
    {primaryCategory && <><a href={`/category/${primaryCategory.slug}`}>{primaryCategory.name}</a> &rsaquo;</>}
    <span>{tool.name}</span>
  </div>

  <!-- HERO -->
  <section class="review-hero">
    <div class="hero-id">
      <ToolLogo tool={tool} size={56} />
      <div class="hero-text">
        <div class="hero-title-row">
          <h1>{tool.name} Review</h1>
          <span class="hero-rating-badge">★ {tool.rating}</span>
        </div>
        <p class="tool-desc">{tool.description}</p>
        <p class="review-date">Reviewed {reviewDateStr}</p>
      </div>
    </div>
  </section>

  <!-- SUMMARY CARD -->
  <section class="summary-card">
    <div class="summary-grid">
      <div class="summary-item">
        <span class="label">Rating</span>
        <span class="value rating-val">★ {tool.rating} / 5</span>
      </div>
      <div class="summary-item">
        <span class="label">Pricing</span>
        <span class="value">{tool.pricing}</span>
      </div>
      {tool.startingPrice && (
        <div class="summary-item">
          <span class="label">Starting Price</span>
          <span class="value">{tool.startingPrice}</span>
        </div>
      )}
      {primaryCategory && (
        <div class="summary-item">
          <span class="label">Category</span>
          <a href={`/category/${primaryCategory.slug}`} class="value cat-link">
            {primaryCategory.name}
          </a>
        </div>
      )}
    </div>
    <div class="summary-actions">
      <a href={`/go/${tool.slug}`}
         class="visit-btn"
         rel={tool.affiliate ? "sponsored noopener" : "noopener"}
         target="_blank">
        Visit {tool.name} ↗
      </a>
      {tool.affiliate && <span class="aff-note">Affiliate link</span>}
      {tool.alternatives && tool.alternatives.length > 0 && (
        <a href={`/alternatives/${tool.slug}`} class="alt-link">
          {tool.alternatives.length} Alternatives &rarr;
        </a>
      )}
      {allCategories.map((cat) => (
        <a href={`/category/${cat.slug}`} class="tag">{cat.name}</a>
      ))}
    </div>
  </section>

  <!-- TABLE OF CONTENTS -->
  {toc.length > 2 && (
    <nav class="toc" aria-label="Jump to section">
      <div class="toc-inner">
        {toc.map((item) => (
          <a href={`#${item.id}`} class="toc-link">{item.label}</a>
        ))}
      </div>
    </nav>
  )}

  <!-- OVERVIEW -->
  {tool.overview && (
    <section class="detail-section" id="overview">
      <h2>Overview</h2>
      {(tool.overview as string).split('\n\n').map((para: string) => (
        <p class="overview-text">{para}</p>
      ))}
    </section>
  )}

  <!-- PROS & CONS -->
  {((tool.pros as string[] | undefined)?.length > 0 || (tool.cons as string[] | undefined)?.length > 0) && (
    <section class="detail-section" id="pros-cons">
      <h2>Pros &amp; Cons</h2>
      <div class="pros-cons-grid">
        {(tool.pros as string[] | undefined)?.length > 0 && (
          <div class="pros-box">
            <div class="pc-header">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Pros
            </div>
            <ul class="pc-list">
              {(tool.pros as string[]).map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )}
        {(tool.cons as string[] | undefined)?.length > 0 && (
          <div class="cons-box">
            <div class="pc-header">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
              Cons
            </div>
            <ul class="pc-list">
              {(tool.cons as string[]).map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- BEST FOR -->
  {(tool.bestFor as string[] | undefined)?.length > 0 && (
    <section class="detail-section" id="best-for">
      <h2>Best For</h2>
      <div class="best-for-grid">
        {(tool.bestFor as string[]).map((item) => (
          <div class="best-for-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" style="flex-shrink:0;margin-top:3px" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- KEY FEATURES -->
  {(tool.keyFeatures as unknown[] | undefined)?.length > 0 && (
    <section class="detail-section" id="key-features">
      <h2>Key Features</h2>
      <div class="features-grid">
        {(tool.keyFeatures as { title: string; description: string }[]).map((f) => (
          <div class="feature-card">
            <div class="feature-title">{f.title}</div>
            <p class="feature-desc">{f.description}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- USE CASES -->
  {(tool.useCases as string[] | undefined)?.length > 0 && (
    <section class="detail-section" id="use-cases">
      <h2>Use Cases</h2>
      <ol class="use-cases-list">
        {(tool.useCases as string[]).map((item, i) => (
          <li class="use-case-item">
            <span class="uc-num">{String(i + 1).padStart(2, '0')}</span>
            <span>{item}</span>
          </li>
        ))}
      </ol>
    </section>
  )}

  <!-- PRICING BREAKDOWN -->
  {(tool.pricingBreakdown as { plans?: { name: string; price: string; description: string }[]; note?: string } | undefined)?.plans?.length > 0 && (
    <section class="detail-section" id="pricing">
      <h2>Pricing Breakdown</h2>
      <div class="pricing-table">
        {(tool.pricingBreakdown as { plans: { name: string; price: string; description: string }[]; note?: string }).plans.map((plan) => (
          <div class="pricing-plan">
            <div class="plan-name">{plan.name}</div>
            <div class="plan-price">{plan.price}</div>
            <p class="plan-desc">{plan.description}</p>
          </div>
        ))}
      </div>
      {(tool.pricingBreakdown as { note?: string }).note && (
        <p class="pricing-note">{(tool.pricingBreakdown as { note: string }).note}</p>
      )}
    </section>
  )}

  <!-- WHO SHOULD AVOID -->
  {(tool.whoShouldAvoid as string[] | undefined)?.length > 0 && (
    <section class="detail-section avoid-section" id="who-should-avoid">
      <h2>Who Should Avoid It</h2>
      <ul class="avoid-list">
        {(tool.whoShouldAvoid as string[]).map((item) => (
          <li class="avoid-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" style="flex-shrink:0;margin-top:2px" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- FINAL VERDICT -->
  {tool.verdict?.summary && (
    <section class="detail-section" id="verdict">
      <h2>Final Verdict</h2>
      <div class="verdict-box">
        <p class="verdict-text">{(tool.verdict as { summary: string }).summary}</p>
        <div class="verdict-footer">
          <div class="verdict-rating">
            <span class="vr-score">★ {(tool.verdict as { score?: number }).score ?? tool.rating}</span>
            <span class="vr-label">/ 5</span>
          </div>
          <a href={`/go/${tool.slug}`}
             class="visit-btn"
             rel={tool.affiliate ? "sponsored noopener" : "noopener"}
             target="_blank">
            Visit {tool.name} ↗
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ALTERNATIVES -->
  {alternativeTools.length > 0 && (
    <section class="detail-section alt-section" id="alternatives">
      <div class="section-hd">
        <div>
          <h2>Best Alternatives to {tool.name}</h2>
          <p class="section-sub">Compare {tool.name} with top alternatives</p>
        </div>
        <a href={`/alternatives/${tool.slug}`} class="see-all">See all alternatives &rarr;</a>
      </div>
      <div class="alt-list">
        {alternativeTools.map((t) => (
          <AltCard tool={t} compareSlug={[tool.slug, t.slug].sort().join("-vs-")} />
        ))}
      </div>
    </section>
  )}

  <!-- RELATED GUIDES -->
  {relatedGuides.length > 0 && (
    <section class="detail-section" id="guides">
      <div class="section-hd">
        <div>
          <h2>Expert Guides Featuring {tool.name}</h2>
          <p class="section-sub">In-depth comparisons and ranked lists</p>
        </div>
        <a href="/best/" class="see-all">All guides &rarr;</a>
      </div>
      <div class="guides-grid">
        {relatedGuides.map((guide) => (
          <a href={`/best/${guide.slug}/`} class="guide-card">
            <div class="gc-cat">{guide.categoryName}</div>
            <div class="gc-title">{guide.h1}</div>
            <div class="gc-meta">{guide.toolSlugs.length} tools compared &rarr;</div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- FAQ (auto-generated) -->
  {autoFaqs.length > 0 && (
    <section class="detail-section faq-section" id="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {autoFaqs.map(({ question, answer }) => (
          <details class="faq-item">
            <summary class="faq-q">
              <span>{question}</span>
              <svg class="faq-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <div class="faq-a">{answer}</div>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- RELATED TOOLS -->
  {relatedTools.length > 0 && (
    <section class="detail-section" id="related">
      <div class="section-hd">
        <div>
          <h2>Related Tools</h2>
          <p class="section-sub">Other {primaryCategory?.name ?? "software"} tools you might like</p>
        </div>
        {primaryCategory && (
          <a href={`/category/${primaryCategory.slug}`} class="see-all">See all {primaryCategory.name} &rarr;</a>
        )}
      </div>
      <div class="tools-grid">
        {relatedTools.map((t) => <ToolCard tool={t} />)}
      </div>
    </section>
  )}

  <!-- PREV / NEXT -->
  <nav class="prev-next" aria-label="Review navigation">
    {prevTool ? (
      <a href={`/reviews/${prevTool.slug}`} class="pn-card prev">
        <ToolLogo tool={prevTool} size={36} />
        <div class="pn-meta">
          <span class="pn-dir">&#8592; Previous</span>
          <span class="pn-name">{prevTool.name}</span>
          <span class="pn-rating">★ {prevTool.rating}</span>
        </div>
      </a>
    ) : <div />}
    {nextTool ? (
      <a href={`/reviews/${nextTool.slug}`} class="pn-card next">
        <div class="pn-meta">
          <span class="pn-dir">Next &rarr;</span>
          <span class="pn-name">{nextTool.name}</span>
          <span class="pn-rating">★ {nextTool.rating}</span>
        </div>
        <ToolLogo tool={nextTool} size={36} />
      </a>
    ) : <div />}
  </nav>

</MainLayout>

<!-- STICKY CTA -->
<div id="sticky-cta" class="sticky-cta" aria-hidden="true">
  <div class="sticky-inner">
    <div class="sticky-info">
      <ToolLogo tool={tool} size={28} />
      <span class="sticky-name">{tool.name}</span>
      {tool.startingPrice && <span class="sticky-price">{tool.startingPrice}</span>}
      <span class="sticky-rating">★ {tool.rating}</span>
    </div>
    <a href={`/go/${tool.slug}`}
       class="sticky-btn"
       rel={tool.affiliate ? "sponsored noopener" : "noopener"}
       target="_blank">
      Visit {tool.name} ↗
    </a>
  </div>
</div>

<script>
  const cta    = document.getElementById('sticky-cta');
  const anchor = document.querySelector('.summary-card');
  if (cta && anchor) {
    new IntersectionObserver(
      ([e]) => {
        cta.classList.toggle('is-visible', !e.isIntersecting);
        cta.setAttribute('aria-hidden', String(e.isIntersecting));
      },
      { threshold: 0 }
    ).observe(anchor);
  }
</script>

<style>
  .breadcrumb {
    font-size: 0.875rem;
    color: #9ca3af;
    padding: 24px 0 0;
    margin-bottom: 24px;
  }
  .breadcrumb a { color: #6b7280; }
  .breadcrumb a:hover { color: #7C3AED; text-decoration: none; }

  /* HERO */
  .review-hero { margin-bottom: 28px; }
  .hero-id {
    display: flex;
    align-items: flex-start;
    gap: 18px;
  }
  .hero-text { flex: 1; min-width: 0; }
  .hero-title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .review-hero h1 {
    font-size: 2.1rem;
    font-weight: 800;
    color: #111827;
    margin: 0;
    line-height: 1.15;
  }
  .hero-rating-badge {
    font-size: 0.95rem;
    font-weight: 700;
    color: #d97706;
    background: #fef3c7;
    border: 1px solid #fde68a;
    padding: 4px 12px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .tool-desc {
    font-size: 1.05rem;
    color: #6b7280;
    margin: 0 0 6px;
  }
  .review-date {
    font-size: 0.78rem;
