---
import tools from "../../data/generated/tools-enriched.json";
import taxonomies from "../../data/taxonomies.json";
import MainLayout from "../../layouts/MainLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import ToolLogo from "../../components/ToolLogo.astro";
import AltCard from "../../components/AltCard.astro";

export async function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;

const primaryCategory = taxonomies.find((c) => c.slug === tool.primaryCategory);
const allCategories = taxonomies.filter((c) => tool.categories.includes(c.slug));
// Alternatives: use defined list first, fallback to top-rated same-category tools
let alternativeTools = tools.filter((t) => tool.alternatives.includes(t.slug)).slice(0, 4);
if (alternativeTools.length === 0) {
  alternativeTools = tools
    .filter((t) => t.slug !== tool.slug && t.categories.some((c) => tool.categories.includes(c)))
    .sort((a, b) => b.rating - a.rating)
    .slice(0, 4);
}

// Related Tools: same category, sorted by closest rating to current tool; excl. current + alternatives; max 4
const altSlugs = new Set(alternativeTools.map((t) => t.slug));
const relatedTools = tools
  .filter((t) =>
    t.slug !== tool.slug &&
    !altSlugs.has(t.slug) &&
    t.categories.some((c) => tool.categories.includes(c))
  )
  .sort((a, b) => Math.abs(a.rating - tool.rating) - Math.abs(b.rating - tool.rating))
  .slice(0, 4);

// Previous / Next (by position in dataset)
const toolIndex = tools.findIndex((t) => t.slug === tool.slug);
const prevTool  = toolIndex > 0                 ? tools[toolIndex - 1] : null;
const nextTool  = toolIndex < tools.length - 1  ? tools[toolIndex + 1] : null;

// JSON-LD: WebPage + BreadcrumbList + SoftwareApplication + Review
const SITE    = "https://zotopie.com";
const pageUrl = `${SITE}/reviews/${tool.slug}/`;
const pageTitle = `${tool.name} Review 2026: Pricing, Pros & Cons | Zotopie`;
const pageDesc  = `${tool.name} review 2026: ${tool.description}. Compare pricing, pros, cons, and top alternatives.`;

// Extract numeric price from strings like "$129/mo", "from $99/month", "$9.99/mo"
function parsePrice(raw: string | undefined): string | null {
  if (!raw) return null;
  const m = raw.match(/[\d]+\.?\d*/);
  return m ? m[0] : null;
}

// Build Offer node with correct price field
const numericPrice =
  tool.pricing === "Free" || (tool.pricing === "Freemium" && !tool.startingPrice)
    ? "0"
    : parsePrice(tool.startingPrice) ?? null;

const offerNode: Record<string, unknown> = {
  "@type": "Offer",
  priceCurrency: "USD",
  ...(numericPrice !== null ? { price: numericPrice } : {}),
  ...(tool.startingPrice ? { description: tool.startingPrice } : {}),
};

// applicationCategory: use primary category name; fallback to generic
const appCategory = primaryCategory?.name ?? "WebApplication";

const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "Home",    item: `${SITE}/` },
  { "@type": "ListItem", position: 2, name: "Reviews", item: `${SITE}/reviews/` },
  ...(primaryCategory
    ? [
        { "@type": "ListItem", position: 3, name: primaryCategory.name, item: `${SITE}/category/${primaryCategory.slug}/` },
        { "@type": "ListItem", position: 4, name: tool.name },
      ]
    : [{ "@type": "ListItem", position: 3, name: tool.name }]),
];

const jsonLdStr = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: pageTitle,
      description: pageDesc,
      datePublished: tool.addedDate,
      breadcrumb: { "@id": `${pageUrl}#breadcrumb` },
      publisher: { "@type": "Organization", name: "Zotopie", url: SITE },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: breadcrumbItems,
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${pageUrl}#software`,
      name: tool.name,
      url: tool.website,
      applicationCategory: appCategory,
      operatingSystem: "Web, Browser",
      offers: offerNode,
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: tool.rating,
        bestRating: "5",
        worstRating: "1",
        ratingCount: "1",
      },
    },
    {
      "@type": "Review",
      "@id": `${pageUrl}#review`,
      name: `${tool.name} Review 2026`,
      author: { "@type": "Organization", name: "Zotopie", url: SITE },
      datePublished: tool.addedDate,
      reviewBody: tool.overview || tool.description,
      reviewRating: {
        "@type": "Rating",
        ratingValue: String(tool.rating),
        bestRating: "5",
        worstRating: "1",
      },
      itemReviewed: { "@id": `${pageUrl}#software` },
    },
  ],
});
---

<MainLayout
  title={pageTitle}
  description={pageDesc}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLdStr} />
  </Fragment>

  <!-- BREADCRUMB -->
  <div class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/reviews">Reviews</a> &rsaquo;
    {primaryCategory && <><a href={`/category/${primaryCategory.slug}`}>{primaryCategory.name}</a> &rsaquo;</>}
    <span>{tool.name}</span>
  </div>

  <!-- HERO -->
  <section class="review-hero">
    <div class="hero-id">
      <ToolLogo tool={tool} size={56} />
      <div>
        <h1>{tool.name} Review</h1>
        <p class="tool-desc">{tool.description}</p>
      </div>
    </div>
  </section>

  <!-- SUMMARY CARD -->
  <section class="summary-card">
    <div class="summary-grid">
      <div class="summary-item">
        <span class="label">Rating</span>
        <span class="value rating-val">★ {tool.rating} / 5</span>
      </div>
      <div class="summary-item">
        <span class="label">Pricing</span>
        <span class="value">{tool.pricing}</span>
      </div>
      {tool.startingPrice && (
        <div class="summary-item">
          <span class="label">Starting Price</span>
          <span class="value">{tool.startingPrice}</span>
        </div>
      )}
      {primaryCategory && (
        <div class="summary-item">
          <span class="label">Category</span>
          <a href={`/category/${primaryCategory.slug}`} class="value cat-link">
            {primaryCategory.name}
          </a>
        </div>
      )}
    </div>
    <div class="summary-actions">
      <a href={`/go/${tool.slug}`} class="visit-btn">
        Visit {tool.name} &rarr;
      </a>
      {tool.alternatives && tool.alternatives.length > 0 && (
        <a href={`/alternatives/${tool.slug}`} class="alt-link">
          {tool.alternatives.length} Alternatives &rarr;
        </a>
      )}
      {allCategories.map((cat) => (
        <a href={`/category/${cat.slug}`} class="tag">{cat.name}</a>
      ))}
    </div>
  </section>

  <!-- OVERVIEW -->
  {tool.overview && (
    <section class="detail-section">
      <h2>Overview</h2>
      <p class="overview-text">{tool.overview}</p>
    </section>
  )}

  <!-- PROS & CONS -->
  {(tool.pros?.length > 0 || tool.cons?.length > 0) && (
    <section class="detail-section">
      <h2>Pros & Cons</h2>
      <div class="pros-cons-grid">
        {tool.pros?.length > 0 && (
          <div class="pros-box">
            <div class="pc-header">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Pros
            </div>
            <ul class="pc-list">
              {tool.pros.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )}
        {tool.cons?.length > 0 && (
          <div class="cons-box">
            <div class="pc-header">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
              Cons
            </div>
            <ul class="pc-list">
              {tool.cons.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- BEST FOR -->
  {tool.bestFor?.length > 0 && (
    <section class="detail-section">
      <h2>Best For</h2>
      <div class="best-for-grid">
        {tool.bestFor.map((item) => (
          <div class="best-for-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5" style="flex-shrink:0;margin-top:3px">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- RELATED TOOLS (C24) — same category, placed right after Best For -->
  {relatedTools.length > 0 && (
    <section class="detail-section">
      <div class="section-hd">
        <div>
          <h2>Related Tools</h2>
          <p class="section-sub">Other {primaryCategory?.name ?? "software"} tools you might like</p>
        </div>
        {primaryCategory && (
          <a href={`/category/${primaryCategory.slug}`} class="see-all">See all {primaryCategory.name} &rarr;</a>
        )}
      </div>
      <div class="tools-grid">
        {relatedTools.map((t) => <ToolCard tool={t} />)}
      </div>
    </section>
  )}

  <!-- KEY FEATURES -->
  {tool.keyFeatures?.length > 0 && (
    <section class="detail-section">
      <h2>Key Features</h2>
      <div class="features-grid">
        {tool.keyFeatures.map((f: { title: string; description: string }) => (
          <div class="feature-card">
            <div class="feature-title">{f.title}</div>
            <p class="feature-desc">{f.description}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- USE CASES -->
  {tool.useCases?.length > 0 && (
    <section class="detail-section">
      <h2>Use Cases</h2>
      <ol class="use-cases-list">
        {tool.useCases.map((item: string, i: number) => (
          <li class="use-case-item">
            <span class="uc-num">{String(i + 1).padStart(2, '0')}</span>
            <span>{item}</span>
          </li>
        ))}
      </ol>
    </section>
  )}

  <!-- PRICING BREAKDOWN -->
  {tool.pricingBreakdown?.plans?.length > 0 && (
    <section class="detail-section">
      <h2>Pricing Breakdown</h2>
      <div class="pricing-table">
        {tool.pricingBreakdown.plans.map((plan: { name: string; price: string; description: string }) => (
          <div class="pricing-plan">
            <div class="plan-name">{plan.name}</div>
            <div class="plan-price">{plan.price}</div>
            <p class="plan-desc">{plan.description}</p>
          </div>
        ))}
      </div>
      {tool.pricingBreakdown.note && (
        <p class="pricing-note">{tool.pricingBreakdown.note}</p>
      )}
    </section>
  )}

  <!-- WHO SHOULD AVOID -->
  {tool.whoShouldAvoid?.length > 0 && (
    <section class="detail-section">
      <h2>Who Should Avoid It</h2>
      <ul class="avoid-list">
        {tool.whoShouldAvoid.map((item: string) => (
          <li class="avoid-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" style="flex-shrink:0;margin-top:2px">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- FINAL VERDICT -->
  {tool.verdict?.summary && (
    <section class="detail-section">
      <h2>Final Verdict</h2>
      <div class="verdict-box">
        <p class="verdict-text">{tool.verdict.summary}</p>
        <div class="verdict-footer">
          <div class="verdict-rating">
            <span class="vr-score">★ {tool.verdict.score ?? tool.rating}</span>
            <span class="vr-label">/ 5</span>
          </div>
          <a href={`/go/${tool.slug}`} class="visit-btn">
            Visit {tool.name} &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ALTERNATIVES (C25) — "Best Alternatives to {tool}" -->
  {alternativeTools.length > 0 && (
    <section class="detail-section alt-section">
      <div class="section-hd">
        <div>
          <h2>Best Alternatives to {tool.name}</h2>
          <p class="section-sub">Compare {tool.name} with top alternatives</p>
        </div>
        <a href={`/alternatives/${tool.slug}`} class="see-all">See all alternatives &rarr;</a>
      </div>
      <div class="alt-list">
        {alternativeTools.map((t) => (
          <AltCard tool={t} />
        ))}
      </div>
    </section>
  )}

  <!-- PREV / NEXT -->
  <nav class="prev-next" aria-label="Review navigation">
    {prevTool ? (
      <a href={`/reviews/${prevTool.slug}`} class="pn-card prev">
        <ToolLogo tool={prevTool} size={36} />
        <div class="pn-meta">
          <span class="pn-dir">&#8592; Previous</span>
          <span class="pn-name">{prevTool.name}</span>
          <span class="pn-rating">★ {prevTool.rating}</span>
        </div>
      </a>
    ) : <div />}
    {nextTool ? (
      <a href={`/reviews/${nextTool.slug}`} class="pn-card next">
        <div class="pn-meta">
          <span class="pn-dir">Next &rarr;</span>
          <span class="pn-name">{nextTool.name}</span>
          <span class="pn-rating">★ {nextTool.rating}</span>
        </div>
        <ToolLogo tool={nextTool} size={36} />
      </a>
    ) : <div />}
  </nav>

</MainLayout>

<!-- STICKY CTA -->
<div id="sticky-cta" class="sticky-cta" aria-hidden="true">
  <div class="sticky-inner">
    <div class="sticky-info">
      <ToolLogo tool={tool} size={28} />
      <span class="sticky-name">{tool.name}</span>
      {tool.startingPrice && <span class="sticky-price">{tool.startingPrice}</span>}
      <span class="sticky-rating">★ {tool.rating}</span>
    </div>
    <a href={`/go/${tool.slug}`} class="sticky-btn">
      Visit {tool.name} &rarr;
    </a>
  </div>
</div>

<script>
  const cta     = document.getElementById('sticky-cta');
  const anchor  = document.querySelector('.summary-card');
  if (cta && anchor) {
    new IntersectionObserver(
      ([e]) => {
        cta.classList.toggle('is-visible', !e.isIntersecting);
        cta.setAttribute('aria-hidden', String(e.isIntersecting));
      },
      { threshold: 0 }
    ).observe(anchor);
  }
</script>

<style>
  .breadcrumb {
    font-size: 0.875rem;
    color: #9ca3af;
    padding: 24px 0 0;
    margin-bottom: 24px;
  }
  .breadcrumb a { color: #6b7280; }
  .breadcrumb a:hover { color: #2563eb; text-decoration: none; }

  /* HERO */
  .review-hero { margin-bottom: 28px; }
  .hero-id {
    display: flex;
    align-items: flex-start;
    gap: 18px;
  }
  .review-hero h1 {
    font-size: 2.1rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 8px;
    line-height: 1.15;
  }
  .tool-desc {
    font-size: 1.05rem;
    color: #6b7280;
    margin: 0;
  }

  /* SUMMARY CARD */
  .summary-card {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 24px;
    margin-bottom: 8px;
  }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
  }
  .summary-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #9ca3af;
  }
  .value {
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
  }
  .rating-val { color: #d97706; }
  .cat-link { color: #2563eb; text-decoration: none; }
  .cat-link:hover { text-decoration: underline; }

  .summary-actions {
    border-top: 1px solid #e5e7eb;
    padding-top: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .visit-btn {
    display: inline-block;
    padding: 10px 22px;
    background: #2563eb;
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .visit-btn:hover { background: #1d4ed8; text-decoration: none; }
  .alt-link {
    display: inline-block;
    padding: 9px 18px;
    border: 1.5px solid #2563eb;
    color: #2563eb;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
  }
  .alt-link:hover { background: #eff6ff; text-decoration: none; }
  .tag {
    display: inline-block;
    padding: 6px 13px;
    background: #eff6ff;
    color: #2563eb;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid #bfdbfe;
  }
  .tag:hover { background: #dbeafe; text-decoration: none; }

  /* SECTIONS */
  .detail-section {
    border-top: 1px solid #e5e7eb;
    padding: 36px 0;
  }
  .detail-section h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 18px;
  }

  /* OVERVIEW */
  .overview-text {
    font-size: 1rem;
    color: #374151;
    line-height: 1.75;
    max-width: 780px;
  }

  /* PROS & CONS */
  .pros-cons-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .pros-box, .cons-box {
    border-radius: 12px;
    padding: 20px;
  }
  .pros-box {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
  }
  .cons-box {
    background: #fff7f7;
    border: 1px solid #fecaca;
  }
  .pc-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 14px;
  }
  .pros-box .pc-header { color: #15803d; }
  .cons-box .pc-header { color: #b91c1c; }
  .pc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pc-list li {
    font-size: 0.9rem;
    color: #374151;
    padding-left: 18px;
    position: relative;
    line-height: 1.5;
  }
  .pros-box .pc-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #15803d;
    font-weight: 700;
    font-size: 0.8rem;
  }
  .cons-box .pc-list li::before {
    content: "✗";
    position: absolute;
    left: 0;
    color: #b91c1c;
    font-weight: 700;
    font-size: 0.8rem;
  }

  /* BEST FOR */
  .best-for-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
  }
  .best-for-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    background: #f8faff;
    border: 1px solid #dbeafe;
    border-radius: 10px;
    font-size: 0.9rem;
    color: #1e3a8a;
    font-weight: 500;
    line-height: 1.4;
  }

  /* KEY FEATURES */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
  }
  .feature-card {
    padding: 18px 20px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .feature-card:hover { border-color: #2563eb; box-shadow: 0 2px 10px rgba(37,99,235,0.07); }
  .feature-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 6px;
  }
  .feature-desc {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  /* USE CASES */
  .use-cases-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 780px;
  }
  .use-case-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 18px;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    font-size: 0.9rem;
    color: #374151;
    line-height: 1.55;
  }
  .uc-num {
    font-size: 0.7rem;
    font-weight: 800;
    color: #2563eb;
    background: #eff6ff;
    border-radius: 6px;
    padding: 2px 7px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* PRICING BREAKDOWN */
  .pricing-table {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 14px;
  }
  .pricing-plan {
    padding: 20px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .plan-name {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #9ca3af;
  }
  .plan-price {
    font-size: 1.45rem;
    font-weight: 800;
    color: #111827;
    line-height: 1.1;
    margin: 4px 0 2px;
  }
  .plan-desc {
    font-size: 0.8rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.5;
  }
