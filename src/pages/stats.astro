---
import tools from "../data/generated/tools-enriched.json";
import taxonomies from "../data/taxonomies.json";
import MainLayout from "../layouts/MainLayout.astro";

const toolMapStr = JSON.stringify(
  Object.fromEntries(tools.map((t) => [t.slug, { name: t.name, cat: t.primaryCategory, affiliate: t.affiliate }]))
);
const catMapStr = JSON.stringify(
  Object.fromEntries(taxonomies.map((c) => [c.slug, c.name]))
);
---

<MainLayout title="Click Stats | Zotopie" description="Outbound click statistics for Zotopie tools.">
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <section class="stats-hero">
    <h1>Click Analytics</h1>
    <p class="hero-sub">Outbound clicks tracked in your browser — local data only, no server involved.</p>
    <div class="hero-actions">
      <button id="btn-clear" class="btn-danger">Clear All Data</button>
      <button id="btn-export" class="btn-secondary">Export JSON</button>
    </div>
  </section>

  <!-- SUMMARY -->
  <div class="summary-row" id="summary-row">
    <div class="stat-card"><div class="sc-val" id="total-clicks">—</div><div class="sc-label">Total Clicks</div></div>
    <div class="stat-card"><div class="sc-val" id="unique-tools">—</div><div class="sc-label">Unique Tools</div></div>
    <div class="stat-card"><div class="sc-val" id="affiliate-clicks">—</div><div class="sc-label">Affiliate Clicks</div></div>
    <div class="stat-card"><div class="sc-val" id="top-cat">—</div><div class="sc-label">Top Category</div></div>
  </div>

  <!-- TOP TOOLS TABLE -->
  <section class="stats-section">
    <h2>Top Clicked Tools</h2>
    <div id="no-data" class="no-data" style="display:none">
      <p>No click data yet. Visit tool pages and click "Visit Tool" to start tracking.</p>
    </div>
    <div class="table-wrap">
      <table class="stats-table" id="clicks-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Tool</th>
            <th>Category</th>
            <th>Affiliate</th>
            <th>Clicks</th>
            <th>Last Clicked</th>
          </tr>
        </thead>
        <tbody id="table-body"></tbody>
      </table>
    </div>
  </section>

  <!-- BY CATEGORY -->
  <section class="stats-section">
    <h2>Clicks by Category</h2>
    <div id="cat-chart" class="cat-chart"></div>
  </section>
</MainLayout>

<script define:vars={{ toolMapStr, catMapStr }}>
  const TOOL_MAP = JSON.parse(toolMapStr);
  const CAT_MAP  = JSON.parse(catMapStr);

  function loadData() {
    try {
      const raw = localStorage.getItem("ztp_clicks");
      return raw ? JSON.parse(raw) : {};
    } catch (_) { return {}; }
  }

  function fmt(ts) {
    if (!ts) return "—";
    return new Date(ts).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
  }

  function render() {
    const data = loadData();
    const slugs = Object.keys(data);

    // SUMMARY
    const totalClicks     = slugs.reduce((s, k) => s + (data[k].count || 0), 0);
    const affiliateClicks = slugs.filter((k) => data[k].affiliate).reduce((s, k) => s + (data[k].count || 0), 0);

    document.getElementById("total-clicks").textContent     = totalClicks;
    document.getElementById("unique-tools").textContent     = slugs.length;
    document.getElementById("affiliate-clicks").textContent = affiliateClicks;

    // Category tallies
    const catTotals = {};
    for (const slug of slugs) {
      const info = TOOL_MAP[slug];
      if (!info) continue;
      const cat = info.cat;
      catTotals[cat] = (catTotals[cat] || 0) + (data[slug].count || 0);
    }
    const topCatSlug = Object.entries(catTotals).sort((a, b) => b[1] - a[1])[0]?.[0];
    document.getElementById("top-cat").textContent = topCatSlug ? (CAT_MAP[topCatSlug] ?? topCatSlug) : "—";

    if (slugs.length === 0) {
      document.getElementById("no-data").style.display = "block";
      document.getElementById("clicks-table").style.display = "none";
    } else {
      document.getElementById("no-data").style.display = "none";
      document.getElementById("clicks-table").style.display = "";
    }

    // TABLE
    const sorted = [...slugs].sort((a, b) => (data[b].count || 0) - (data[a].count || 0));
    const tbody = document.getElementById("table-body");
    tbody.innerHTML = sorted.map((slug, i) => {
      const entry = data[slug];
      const info  = TOOL_MAP[slug];
      const name  = info?.name ?? slug;
      const cat   = info?.cat ? (CAT_MAP[info.cat] ?? info.cat) : "—";
      const aff   = (info?.affiliate || entry.affiliate) ? '<span class="aff-badge">✓</span>' : "—";
      return `
        <tr>
          <td class="rank">${i + 1}</td>
          <td><a href="/reviews/${slug}" class="tl">${name}</a></td>
          <td><span class="cat-tag">${cat}</span></td>
          <td>${aff}</td>
          <td class="click-count">${entry.count || 0}</td>
          <td class="last-date">${fmt(entry.last)}</td>
        </tr>
      `;
    }).join("");

    // CATEGORY CHART (simple bar)
    const catChart = document.getElementById("cat-chart");
    const catEntries = Object.entries(catTotals).sort((a, b) => b[1] - a[1]);
    const maxVal = catEntries[0]?.[1] || 1;
    catChart.innerHTML = catEntries.length === 0
      ? "<p class='no-data-inline'>No data yet.</p>"
      : catEntries.map(([cat, count]) => `
          <div class="bar-row">
            <div class="bar-label">${CAT_MAP[cat] ?? cat}</div>
            <div class="bar-track">
              <div class="bar-fill" style="width:${Math.round((count / maxVal) * 100)}%"></div>
            </div>
            <div class="bar-count">${count}</div>
          </div>
        `).join("");
  }

  // ACTIONS
  document.getElementById("btn-clear").addEventListener("click", () => {
    if (confirm("Clear all click data?")) {
      localStorage.removeItem("ztp_clicks");
      render();
    }
  });

  document.getElementById("btn-export").addEventListener("click", () => {
    const data = loadData();
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "zotopie-clicks.json";
    a.click();
  });

  render();
</script>

<style>
  .stats-hero {
    padding: 40px 0 28px;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 32px;
  }
  h1 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 6px;
  }
  .hero-sub { font-size: 0.95rem; color: #6b7280; margin-bottom: 16px; }
  .hero-actions { display: flex; gap: 10px; }
  .btn-danger {
    padding: 8px 16px;
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: 7px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }
  .btn-danger:hover { background: #b91c1c; }
  .btn-secondary {
    padding: 8px 16px;
    background: #fff;
    border: 1.5px solid #d1d5db;
    color: #374151;
    border-radius: 7px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }
  .btn-secondary:hover { border-color: #2563eb; color: #2563eb; }

  /* SUMMARY */
  .summary-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 40px;
  }
  .stat-card {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 18px 20px;
    text-align: center;
  }
  .sc-val {
    font-size: 1.8rem;
    font-weight: 800;
    color: #111827;
    margin-bottom: 4px;
  }
  .sc-label { font-size: 0.8rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.06em; }

  /* SECTIONS */
  .stats-section { margin-bottom: 48px; }
  .stats-section h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid #e5e7eb;
  }
  .no-data { padding: 32px; text-align: center; color: #9ca3af; }
  .no-data-inline { color: #9ca3af; font-size: 0.9rem; }

  /* TABLE */
  .table-wrap { overflow-x: auto; }
  .stats-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .stats-table th, .stats-table td {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
  }
  .stats-table th {
    background: #f9fafb;
    font-weight: 700;
    font-size: 0.8rem;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .rank { color: #9ca3af; font-weight: 700; width: 40px; }
  .tl { color: #2563eb; font-weight: 600; text-decoration: none; }
  .tl:hover { text-decoration: underline; }
  .cat-tag {
    font-size: 0.75rem;
    background: #eff6ff;
    color: #2563eb;
    padding: 2px 8px;
    border-radius: 8px;
  }
  .aff-badge {
    font-size: 0.8rem;
    font-weight: 700;
    color: #059669;
    background: #d1fae5;
    padding: 2px 8px;
    border-radius: 8px;
  }
  .click-count { font-weight: 800; color: #111827; }
  .last-date { color: #9ca3af; font-size: 0.82rem; }

  /* BAR CHART */
  .cat-chart { display: flex; flex-direction: column; gap: 10px; }
  .bar-row {
    display: grid;
    grid-template-columns: 200px 1fr 48px;
    align-items: center;
    gap: 12px;
  }
  .bar-label { font-size: 0.875rem; color: #374151; text-align: right; }
  .bar-track {
    background: #f3f4f6;
    border-radius: 6px;
    height: 18px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #2563eb, #60a5fa);
    border-radius: 6px;
    transition: width 0.4s ease;
  }
  .bar-count { font-size: 0.875rem; font-weight: 700; color: #111827; }

  @media (max-width: 640px) {
    .summary-row { grid-template-columns: 1fr 1fr; }
    .bar-row { grid-template-columns: 120px 1fr 36px; }
    .bar-label { font-size: 0.78rem; }
  }
</style>
