---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Page Not Found | Zotopie"
  description="The page you are looking for does not exist."
>

  <section class="not-found">
    <div class="code">404</div>
    <h1>Page Not Found</h1>
    <p>The page you are looking for doesn't exist or has been moved.</p>
    <div class="actions">
      <a href="/" class="btn-primary">Go Home</a>
      <a href="/reviews" class="btn-secondary">Browse Reviews</a>
      <a href="/category" class="btn-secondary">Browse Categories</a>
    </div>
  </section>

</MainLayout>

<style>
  .not-found {
    text-align: center;
    padding: 96px 0;
  }
  .code {
    font-size: 6rem;
    font-weight: 800;
    color: #e5e7eb;
    line-height: 1;
    margin-bottom: 16px;
  }
  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 12px;
  }
  p {
    color: #6b7280;
    margin: 0 0 36px;
  }
  .actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    padding: 10px 24px;
    background: #2563eb;
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #1d4ed8; text-decoration: none; }
  .btn-secondary {
    display: inline-block;
    padding: 10px 24px;
    background: #fff;
    color: #374151;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }
  .btn-secondary:hover { border-color: #2563eb; color: #2563eb; text-decoration: none; }
</style>
