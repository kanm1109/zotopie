---
import tools from "../../data/generated/tools-enriched.json";
import taxonomies from "../../data/taxonomies.json";
import MainLayout from "../../layouts/MainLayout.astro";

// Build all unique pairs
const pairSet = new Set<string>();
for (const tool of tools) {
  if (!tool.alternatives?.length) continue;
  for (const altSlug of tool.alternatives) {
    pairSet.add([tool.slug, altSlug].sort().join("-vs-"));
  }
}

type PairEntry = {
  slug: string;
  nameA: string;
  nameB: string;
  category: string;
  categorySlug: string;
};

const allPairs: PairEntry[] = [];
for (const pair of pairSet) {
  const slugA = tools.find((t) => pair.startsWith(t.slug + "-vs-"))?.slug;
  const slugB = tools.find((t) => pair.endsWith("-vs-" + t.slug))?.slug;
  if (!slugA || !slugB) continue;
  const toolA = tools.find((t) => t.slug === slugA)!;
  const toolB = tools.find((t) => t.slug === slugB)!;
  const cat = taxonomies.find((c) => c.slug === toolA.primaryCategory);
  allPairs.push({
    slug: pair,
    nameA: toolA.name,
    nameB: toolB.name,
    category: cat?.name ?? toolA.primaryCategory,
    categorySlug: toolA.primaryCategory,
  });
}

// Group by category, sort categories and pairs within alphabetically
const grouped: Record<string, PairEntry[]> = {};
for (const p of allPairs) {
  if (!grouped[p.category]) grouped[p.category] = [];
  grouped[p.category].push(p);
}
const sortedCategories = Object.keys(grouped).sort();
for (const cat of sortedCategories) {
  grouped[cat].sort((a, b) => a.nameA.localeCompare(b.nameA) || a.nameB.localeCompare(b.nameB));
}

const SITE = "https://zotopie.com";
const pageTitle = "Compare AI Tools Side-by-Side | Zotopie";
const pageDesc = `Browse ${allPairs.length} head-to-head AI tool comparisons. Compare pricing, features, pros and cons for the most popular tools in every category.`;
---

<MainLayout title={pageTitle} description={pageDesc}>
  <section class="cmp-index-hero">
    <div class="breadcrumb">
      <a href="/">Home</a> &rsaquo; <span>Compare</span>
    </div>
    <h1>Compare AI Tools</h1>
    <p class="hero-sub">{allPairs.length} head-to-head comparisons across {sortedCategories.length} categories</p>
  </section>

  <div class="cmp-index-body">
    {sortedCategories.map((cat) => (
      <section class="cat-group">
        <h2 class="cat-heading">{cat}</h2>
        <ul class="pair-grid">
          {grouped[cat].map((p) => (
            <li>
              <a href={`/compare/${p.slug}/`} class="pair-link">
                {p.nameA} vs {p.nameB}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</MainLayout>

<style>
  .cmp-index-hero {
    padding: 40px 0 32px;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 40px;
  }
  .breadcrumb {
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 16px;
  }
  .breadcrumb a { color: #6b7280; }
  .breadcrumb a:hover { color: #2563eb; text-decoration: none; }
  h1 {
    font-size: 2rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 6px;
  }
  .hero-sub { font-size: 1rem; color: #6b7280; margin: 0; }

  .cmp-index-body { padding-bottom: 60px; }

  .cat-group { margin-bottom: 40px; }
  .cat-heading {
    font-size: 1.1rem;
    font-weight: 700;
    color: #374151;
    margin: 0 0 14px;
    padding-bottom: 8px;
    border-bottom: 2px solid #e5e7eb;
  }

  .pair-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 8px;
  }
  .pair-link {
    display: block;
    padding: 10px 14px;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .pair-link:hover {
    border-color: #2563eb;
    color: #2563eb;
    background: #eff6ff;
  }

  @media (max-width: 640px) {
    h1 { font-size: 1.5rem; }
    .pair-grid { grid-template-columns: 1fr; }
  }
</style>
