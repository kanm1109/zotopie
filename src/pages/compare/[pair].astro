---
import tools from "../../data/generated/tools-enriched.json";
import taxonomies from "../../data/taxonomies.json";
import MainLayout from "../../layouts/MainLayout.astro";
import ToolLogo from "../../components/ToolLogo.astro";

export async function getStaticPaths() {
  const pairs = new Set<string>();
  for (const tool of tools) {
    if (!tool.alternatives?.length) continue;
    for (const altSlug of tool.alternatives) {
      const key = [tool.slug, altSlug].sort().join("-vs-");
      pairs.add(key);
    }
  }

  return [...pairs].flatMap((pair) => {
    const slugA = tools.find((t) => pair.startsWith(t.slug + "-vs-"))?.slug;
    const slugB = tools.find((t) => pair.endsWith("-vs-" + t.slug))?.slug;
    if (!slugA || !slugB) return [];
    const toolA = tools.find((t) => t.slug === slugA)!;
    const toolB = tools.find((t) => t.slug === slugB)!;
    return [{ params: { pair }, props: { toolA, toolB } }];
  });
}

const { toolA, toolB } = Astro.props;

const catA = taxonomies.find((c) => c.slug === toolA.primaryCategory);
const catB = taxonomies.find((c) => c.slug === toolB.primaryCategory);

function formatPricing(tool: typeof toolA) {
  if (tool.pricing === "Free") return "Free";
  if (tool.pricing === "Freemium") return tool.startingPrice ? `Free + from ${tool.startingPrice}` : "Freemium";
  return tool.startingPrice ? `From ${tool.startingPrice}` : tool.pricing;
}

function starsOf(n: number) {
  const full = Math.floor(n);
  const half = n - full >= 0.5 ? 1 : 0;
  const empty = 5 - full - half;
  return "★".repeat(full) + (half ? "½" : "") + "☆".repeat(empty);
}

// "ToolName is a/an [description lowercase, no trailing period]."
function toSentence(name: string, desc: string) {
  const d = desc.replace(/\.$/, "");
  const lower = d.charAt(0).toLowerCase() + d.slice(1);
  const article = /^[aeiou]/i.test(lower) ? "an" : "a";
  return `${name} is ${article} ${lower}.`;
}

// Build expanded intro line: "ToolName is a/an [desc]. It works best for [bf1] and [bf2]."
function buildIntroLine(name: string, desc: string, bestFor: string[]) {
  const base = toSentence(name, desc);
  const bf = (bestFor ?? []).slice(0, 2).filter(Boolean);
  if (bf.length === 0) return base;
  return `${base} It works best for ${bf.join(" and ")}.`;
}
const introA = buildIntroLine(toolA.name, toolA.description, toolA.bestFor ?? []);
const introB = buildIntroLine(toolB.name, toolB.description, toolB.bestFor ?? []);

// --- Winner ---
function pickWinner(a: typeof toolA, b: typeof toolB) {
  if (a.rating > b.rating) return a;
  if (b.rating > a.rating) return b;
  if (a.pricing === "Free" || a.pricing === "Freemium") return a;
  if (b.pricing === "Free" || b.pricing === "Freemium") return b;
  return a;
}
const winnerTool = pickWinner(toolA, toolB);
const loserTool  = winnerTool.slug === toolA.slug ? toolB : toolA;
const isAWinner  = winnerTool.slug === toolA.slug;
const isABetter  = toolA.rating > toolB.rating;
const isBBetter  = toolB.rating > toolA.rating;
const aIsFree    = toolA.pricing === "Free" || toolA.pricing === "Freemium";
const bIsFree    = toolB.pricing === "Free" || toolB.pricing === "Freemium";

// --- Related compare pairs ---
type RelPair = { label: string; slug: string };
const relatedPairs: RelPair[] = [
  ...(toolA.alternatives ?? [])
    .filter((s: string) => s !== toolB.slug)
    .slice(0, 2)
    .flatMap((s: string): RelPair[] => {
      const alt = tools.find((t) => t.slug === s);
      if (!alt) return [];
      return [{ label: `${toolA.name} vs ${alt.name}`, slug: [toolA.slug, s].sort().join("-vs-") }];
    }),
  ...(toolB.alternatives ?? [])
    .filter((s: string) => s !== toolA.slug)
    .slice(0, 1)
    .flatMap((s: string): RelPair[] => {
      const alt = tools.find((t) => t.slug === s);
      if (!alt) return [];
      return [{ label: `${toolB.name} vs ${alt.name}`, slug: [toolB.slug, s].sort().join("-vs-") }];
    }),
].slice(0, 3);

// --- FAQ ---
const q1Answer = (() => {
  if (isABetter)
    return `${toolA.name} scores ${toolA.rating}/5 vs ${toolB.name}'s ${toolB.rating}/5 in our editorial ratings, making it the higher-rated option overall. ${toolA.name} is especially strong for ${toolA.bestFor?.[0] ?? "its core use case"}.`;
  if (isBBetter)
    return `${toolB.name} scores ${toolB.rating}/5 vs ${toolA.name}'s ${toolA.rating}/5 in our editorial ratings, making it the higher-rated option overall. ${toolB.name} is especially strong for ${toolB.bestFor?.[0] ?? "its core use case"}.`;
  return `Both ${toolA.name} and ${toolB.name} are rated equally at ${toolA.rating}/5. ${toolA.name} suits ${toolA.bestFor?.[0] ?? "its primary audience"}, while ${toolB.name} is designed for ${toolB.bestFor?.[0] ?? "its primary audience"}.`;
})();

const q2Answer = (() => {
  if (toolA.pricing === "Free" && toolB.pricing === "Paid")
    return `${toolA.name} is completely free. ${toolB.name} is a paid tool${toolB.startingPrice ? ` starting from ${toolB.startingPrice}` : ""}. For budget-conscious users, ${toolA.name} is the clear winner on price.`;
  if (toolB.pricing === "Free" && toolA.pricing === "Paid")
    return `${toolB.name} is completely free. ${toolA.name} is a paid tool${toolA.startingPrice ? ` starting from ${toolA.startingPrice}` : ""}. For budget-conscious users, ${toolB.name} is the clear winner on price.`;
  if (aIsFree && bIsFree) {
    const aD = toolA.startingPrice ? ` Paid plans start from ${toolA.startingPrice}.` : "";
    const bD = toolB.startingPrice ? ` Paid plans start from ${toolB.startingPrice}.` : "";
    const bothFree = !toolA.startingPrice && !toolB.startingPrice;
    if (bothFree)
      return `Both ${toolA.name} and ${toolB.name} offer free access — no credit card required to get started. Paid plans with higher limits and additional features are available for power users who need more capacity. Check each tool's official pricing page for current plan details and limits.`;
    return `Both tools offer free access. ${toolA.name} is ${toolA.pricing.toLowerCase()}.${aD} ${toolB.name} is ${toolB.pricing.toLowerCase()}.${bD}`;
  }
  if (aIsFree && !bIsFree)
    return `${toolA.name} offers a free plan. ${toolB.name} is a paid tool${toolB.startingPrice ? ` starting from ${toolB.startingPrice}` : ""}. ${toolA.name} wins on affordability for users on a budget.`;
  if (bIsFree && !aIsFree)
    return `${toolB.name} offers a free plan. ${toolA.name} is a paid tool${toolA.startingPrice ? ` starting from ${toolA.startingPrice}` : ""}. ${toolB.name} wins on affordability for users on a budget.`;
  const aStr = toolA.startingPrice ? `starts from ${toolA.startingPrice}` : "is a paid tool";
  const bStr = toolB.startingPrice ? `starts from ${toolB.startingPrice}` : "is a paid tool";
  return `${toolA.name} ${aStr}. ${toolB.name} ${bStr}. Neither tool offers a free plan — visit each pricing page for current rates.`;
})();

const q3Answer = `${toSentence(toolA.name, toolA.description)} ${toSentence(toolB.name, toolB.description)} The key distinction is focus: ${toolA.name} is best suited for ${toolA.bestFor?.[0] ?? "its core users"}, while ${toolB.name} works better for ${toolB.bestFor?.[0] ?? "its core users"}.`;

const autoFaqs = [
  { question: `Is ${toolA.name} better than ${toolB.name}?`, answer: q1Answer },
  { question: `Which is cheaper, ${toolA.name} or ${toolB.name}?`, answer: q2Answer },
  { question: `What is the main difference between ${toolA.name} and ${toolB.name}?`, answer: q3Answer },
];

// --- Enhanced verdict text ---
const verdictText = (() => {
  const w = winnerTool;
  const l = loserTool;
  let text = `Based on our editorial ratings, ${w.name} scores higher (${w.rating}/5 vs ${l.rating}/5).`;
  if ((w.pricing === "Free" || w.pricing === "Freemium") && l.pricing === "Paid") {
    text += ` It also offers a free plan — a significant value advantage over ${l.name}'s paid-only pricing.`;
  }
  text += ` ${w.name} is particularly well-suited for ${w.bestFor?.[0] ?? "its core use case"}.`;
  if (l.bestFor?.[0]) {
    text += ` That said, ${l.name} remains a strong choice if ${l.bestFor[0].toLowerCase()} is your priority.`;
  }
  return text;
})();

// --- JSON-LD ---
const SITE     = "https://zotopie.com";
const pageUrl  = `${SITE}/compare/${toolA.slug}-vs-${toolB.slug}/`;
const pageTitle = `${toolA.name} vs ${toolB.name} (2026): In-Depth Comparison | Zotopie`;
const pageDesc  = `${toolA.name} vs ${toolB.name}: Compare pricing, features, pros & cons side-by-side. Find out which tool is right for you in 2026.`;

const jsonLdStr = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: pageTitle,
      description: pageDesc,
      breadcrumb: {
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home",    item: `${SITE}/` },
          { "@type": "ListItem", position: 2, name: "Compare", item: `${SITE}/compare/` },
          { "@type": "ListItem", position: 3, name: `${toolA.name} vs ${toolB.name}` },
        ],
      },
    },
    {
      "@type": "ItemList",
      name: `${toolA.name} vs ${toolB.name} Comparison`,
      numberOfItems: 2,
      itemListElement: [toolA, toolB].map((t, i) => ({
        "@type": "ListItem",
        position: i + 1,
        item: {
          "@type": "SoftwareApplication",
          name: t.name,
          url: `${SITE}/reviews/${t.slug}/`,
          aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: String(t.rating),
            bestRating: "5",
            worstRating: "1",
            ratingCount: "10",
          },
        },
      })),
    },
    {
      "@type": "FAQPage",
      mainEntity: autoFaqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: { "@type": "Answer", text: faq.answer },
      })),
    },
  ],
});
---

<MainLayout title={pageTitle} description={pageDesc}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLdStr} />
  </Fragment>

  <!-- HERO -->
  <section class="cmp-hero">
    <div class="breadcrumb">
      <a href="/">Home</a> &rsaquo; <a href="/compare/">Compare</a> &rsaquo;
      <span>{toolA.name} vs {toolB.name}</span>
    </div>

    <h1>{toolA.name} vs {toolB.name}</h1>
    <p class="hero-sub">Detailed comparison &mdash; pricing, features, pros &amp; cons</p>

    <div class="cmp-heads">
      <a href={`/reviews/${toolA.slug}/`} class:list={["cmp-head", { "cmp-head--winner": isAWinner }]}>
        {isAWinner && <span class="winner-badge">Winner</span>}
        <ToolLogo tool={toolA} size={56} />
        <div class="ch-name">{toolA.name}</div>
        <div class="ch-rating">
          <span class="rating-num">{toolA.rating}</span>
          <span class="rating-stars">{starsOf(toolA.rating)}</span>
        </div>
        <div class="ch-price">{formatPricing(toolA)}</div>
        <div class="ch-cat">{catA?.name ?? toolA.primaryCategory}</div>
      </a>

      <div class="vs-badge">VS</div>

      <a href={`/reviews/${toolB.slug}/`} class:list={["cmp-head", { "cmp-head--winner": !isAWinner }]}>
        {!isAWinner && <span class="winner-badge">Winner</span>}
        <ToolLogo tool={toolB} size={56} />
        <div class="ch-name">{toolB.name}</div>
        <div class="ch-rating">
          <span class="rating-num">{toolB.rating}</span>
          <span class="rating-stars">{starsOf(toolB.rating)}</span>
        </div>
        <div class="ch-price">{formatPricing(toolB)}</div>
        <div class="ch-cat">{catB?.name ?? toolB.primaryCategory}</div>
      </a>
    </div>

    <!-- HERO CTAs -->
    <div class="hero-ctas">
      <a href={`/go/${toolA.slug}`}
         class="hero-cta-a"
         rel={toolA.affiliate ? "sponsored noopener" : "noopener"}
         target="_blank">
        {aIsFree ? `Try ${toolA.name} Free →` : `Visit ${toolA.name} →`}
      </a>
      <span class="hero-cta-sep">or</span>
      <a href={`/go/${toolB.slug}`}
         class="hero-cta-b"
         rel={toolB.affiliate ? "sponsored noopener" : "noopener"}
         target="_blank">
        {bIsFree ? `Try ${toolB.name} Free →` : `Visit ${toolB.name} →`}
      </a>
    </div>
  </section>

  <!-- EDITORIAL INTRO -->
  <section class="cmp-section intro-section">
    <div class="cmp-intro">
      <p><strong>{toolA.name}</strong> — {introA}</p>
      <p><strong>{toolB.name}</strong> — {introB}</p>
      <p class="intro-closing">This comparison covers pricing, key strengths and limitations, and what each tool does best to help you choose the right fit for your workflow.</p>
    </div>
  </section>

  <!-- QUICK COMPARISON TABLE -->
  <section class="cmp-section">
    <h2>Quick Comparison</h2>
    <div class="cmp-table-wrap">
      <table class="cmp-table">
        <thead>
          <tr>
            <th class="col-label">Feature</th>
            <th class={`col-a${isAWinner ? " col-winner" : ""}`}>{toolA.name}</th>
            <th class={`col-b${!isAWinner ? " col-winner" : ""}`}>{toolB.name}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Rating</td>
            <td class={isABetter ? "cell-better" : ""}>{toolA.rating} / 5</td>
            <td class={isBBetter ? "cell-better" : ""}>{toolB.rating} / 5</td>
          </tr>
          <tr>
            <td>Pricing Model</td>
            <td>{toolA.pricing}</td>
            <td>{toolB.pricing}</td>
          </tr>
          <tr>
            <td>Starting Price</td>
            <td class={(!toolA.startingPrice || toolA.pricing === "Free") ? "cell-better" : ""}>
              {toolA.pricing === "Free" ? "Free" : toolA.startingPrice || "Contact"}
            </td>
            <td class={(!toolB.startingPrice || toolB.pricing === "Free") ? "cell-better" : ""}>
              {toolB.pricing === "Free" ? "Free" : toolB.startingPrice || "Contact"}
            </td>
          </tr>
          <tr>
            <td>Category</td>
            <td>{catA?.name ?? toolA.primaryCategory}</td>
            <td>{catB?.name ?? toolB.primaryCategory}</td>
          </tr>
          <tr>
            <td>Free Plan</td>
            <td class={aIsFree ? "cell-better" : ""}>{aIsFree ? "✓ Yes" : "✗ No"}</td>
            <td class={bIsFree ? "cell-better" : ""}>{bIsFree ? "✓ Yes" : "✗ No"}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- PROS & CONS -->
  <section class="cmp-section pros-cons-section">
    <h2>Pros &amp; Cons</h2>
    <div class="pros-cons-grid">
      <!-- Tool A -->
      <div class="pc-block">
        <div class="pc-header">
          <ToolLogo tool={toolA} size={24} />
          <span>{toolA.name}</span>
        </div>
        {toolA.pros && toolA.pros.length > 0 && (
          <div class="pc-group">
            <div class="pc-label pros-label">Pros</div>
            <ul class="pc-list pros-list">
              {toolA.pros.slice(0, 4).map((p) => <li>{p}</li>)}
            </ul>
          </div>
        )}
        {toolA.cons && toolA.cons.length > 0 && (
          <div class="pc-group">
            <div class="pc-label cons-label">Cons</div>
            <ul class="pc-list cons-list">
              {toolA.cons.slice(0, 3).map((c) => <li>{c}</li>)}
            </ul>
          </div>
        )}
        {(!toolA.pros || toolA.pros.length === 0) && (
          <div class="pc-group pc-empty">
            <p>See our <a href={`/reviews/${toolA.slug}/`}>full {toolA.name} review</a> for a complete breakdown of strengths and limitations.</p>
          </div>
        )}
      </div>

      <!-- Tool B -->
      <div class="pc-block">
        <div class="pc-header">
          <ToolLogo tool={toolB} size={24} />
          <span>{toolB.name}</span>
        </div>
        {toolB.pros && toolB.pros.length > 0 && (
          <div class="pc-group">
            <div class="pc-label pros-label">Pros</div>
            <ul class="pc-list pros-list">
              {toolB.pros.slice(0, 4).map((p) => <li>{p}</li>)}
            </ul>
          </div>
        )}
        {toolB.cons && toolB.cons.length > 0 && (
          <div class="pc-group">
            <div class="pc-label cons-label">Cons</div>
            <ul class="pc-list cons-list">
              {toolB.cons.slice(0, 3).map((c) => <li>{c}</li>)}
            </ul>
          </div>
        )}
        {(!toolB.pros || toolB.pros.length === 0) && (
          <div class="pc-group pc-empty">
            <p>See our <a href={`/reviews/${toolB.slug}/`}>full {toolB.name} review</a> for a complete breakdown of strengths and limitations.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- BEST FOR -->
  <section class="cmp-section">
    <h2>Who Is It For?</h2>
    <div class="bestfor-grid">
      <div class="bf-block">
        <div class="bf-name">{toolA.name} is best for</div>
        <ul class="bf-list">
          {(toolA.bestFor ?? []).slice(0, 4).map((b) => <li>{b}</li>)}
        </ul>
        <a href={`/reviews/${toolA.slug}/`} class="bf-link">Read full {toolA.name} review →</a>
      </div>
      <div class="bf-block">
        <div class="bf-name">{toolB.name} is best for</div>
        <ul class="bf-list">
          {(toolB.bestFor ?? []).slice(0, 4).map((b) => <li>{b}</li>)}
        </ul>
        <a href={`/reviews/${toolB.slug}/`} class="bf-link">Read full {toolB.name} review →</a>
      </div>
    </div>
  </section>

  <!-- DECISION GUIDE -->
  <section class="cmp-section">
    <h2>Which Tool Should You Choose?</h2>
    <div class="choose-grid">
      <div class="choose-block">
        <div class="choose-header">
          <ToolLogo tool={toolA} size={20} />
          <span>Choose {toolA.name} if&hellip;</span>
        </div>
        <ul class="choose-list">
          {(toolA.bestFor ?? []).slice(0, 4).map((b) => <li>{b}</li>)}
        </ul>
      </div>
      <div class="choose-block">
        <div class="choose-header">
          <ToolLogo tool={toolB} size={20} />
          <span>Choose {toolB.name} if&hellip;</span>
        </div>
        <ul class="choose-list">
          {(toolB.bestFor ?? []).slice(0, 4).map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cmp-section faq-section">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      {autoFaqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-q">
            <span>{faq.question}</span>
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-a">{faq.answer}</div>
        </details>
      ))}
    </div>
  </section>

  <!-- VERDICT -->
  <section class="cmp-section verdict-section">
    <h2>Verdict</h2>
    <div class="verdict-box">
      <div class="verdict-winner">
        <ToolLogo tool={winnerTool} size={48} />
        <div>
          <div class="vw-label">Recommended choice</div>
          <div class="vw-name">{winnerTool.name}</div>
        </div>
      </div>
      <p class="verdict-text">{verdictText}</p>
      <div class="verdict-ctas">
        <a href={`/go/${winnerTool.slug}`}
           class="vcta vcta-primary"
           rel={winnerTool.affiliate ? "sponsored noopener" : "noopener"}
           target="_blank">
          {winnerTool.pricing === "Free" || winnerTool.pricing === "Freemium"
            ? `Try ${winnerTool.name} Free →`
            : `Visit ${winnerTool.name} →`}
        </a>
        <a href={`/reviews/${toolA.slug}/`} class="vcta vcta-secondary">{toolA.name} Review</a>
        <a href={`/reviews/${toolB.slug}/`} class="vcta vcta-secondary">{toolB.name} Review</a>
      </div>
    </div>
  </section>

  <!-- EXPLORE MORE -->
  <section class="cmp-section explore-section">
    <h2>Explore More</h2>
    <div class="explore-grid">
      <div class="explore-block">
        <div class="explore-label">All Alternatives</div>
        <a href={`/alternatives/${toolA.slug}/`} class="explore-link">All {toolA.name} alternatives →</a>
        <a href={`/alternatives/${toolB.slug}/`} class="explore-link">All {toolB.name} alternatives →</a>
      </div>
      {relatedPairs.length > 0 && (
        <div class="explore-block">
          <div class="explore-label">Related Comparisons</div>
          {relatedPairs.map((rp) => (
            <a href={`/compare/${rp.slug}/`} class="explore-link">{rp.label} →</a>
          ))}
        </div>
      )}
    </div>
  </section>
</MainLayout>

<style>
  /* HERO */
  .cmp-hero {
    padding: 40px 0 32px;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 40px;
  }
  .breadcrumb {
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 16px;
  }
  .breadcrumb a { color: #6b7280; }
  .breadcrumb a:hover { color: #2563eb; text-decoration: none; }
  h1 {
    font-size: 2rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 6px;
  }
  .hero-sub { font-size: 1rem; color: #6b7280; margin: 0 0 28px; }

  /* COMPARISON HEADS */
  .cmp-heads {
    display: grid;
    grid-template-columns: 1fr 40px 1fr;
    gap: 12px;
    align-items: center;
  }
  .cmp-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: #f9fafb;
    border: 2px solid #e5e7eb;
    border-radius: 16px;
    padding: 24px 16px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
    position: relative;
  }
  .cmp-head:hover { border-color: #2563eb; }
  .cmp-head--winner {
    border-color: #2563eb;
    background: #eff6ff;
  }
  .winner-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #2563eb;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 10px;
