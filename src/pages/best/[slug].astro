    font-size: 1.4rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid #f3f4f6;
    display: flex;
    align-items: center;
    gap: 10px;
