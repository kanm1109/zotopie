  .best-section h2::before {
    content: "";
    display: inline-block;
    width: 4px;
    height: 1.1em;
    background: linear-gradient(180deg, #7C3AED, #7c3aed);
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* COMPARISON TABLE */
  .cmp-table-wrap {
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .cmp-table {
    width: 100%;
