---
import bestPages from "../../data/best-pages.json";
import allTools from "../../data/generated/tools-enriched.json";
import MainLayout from "../../layouts/MainLayout.astro";
import ToolLogo from "../../components/ToolLogo.astro";

export async function getStaticPaths() {
  return bestPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;

// Resolve tools in ranked order
const pageTools = page.toolSlugs
  .map((slug: string) => allTools.find((t) => t.slug === slug))
  .filter(Boolean) as typeof allTools;

// Stats
const avgRating = pageTools.length
  ? (pageTools.reduce((s, t) => s + t.rating, 0) / pageTools.length).toFixed(1)
  : "—";
const freeCount = pageTools.filter(
  (t) => t.pricing === "Free" || t.pricing === "Freemium"
).length;

// Compare pairs between top 3 tools
type ComparePair = { label: string; slug: string };
const top3 = pageTools.slice(0, 3);
const comparePairs: ComparePair[] = [];
for (let i = 0; i < top3.length; i++) {
  for (let j = i + 1; j < top3.length; j++) {
    const a = top3[i].slug;
    const b = top3[j].slug;
    const pairSlug = [a, b].sort().join("-vs-");
    comparePairs.push({ label: `${top3[i].name} vs ${top3[j].name}`, slug: pairSlug });
  }
}

// Winner = first in list (highest-ranked)
const winner = pageTools[0];

// Typed helpers to avoid inline casts in template
const rankLabels = page.rankLabels as Record<string, string>;
const pageFaqs = page.faqs as { q: string; a: string }[];

function formatPricing(tool: typeof allTools[0]) {
  if (tool.pricing === "Free") return "Free";
  if (tool.pricing === "Freemium")
    return tool.startingPrice ? `Free / ${tool.startingPrice}` : "Freemium";
  return tool.startingPrice ? `From ${tool.startingPrice}` : "Paid";
}

// JSON-LD
const SITE = "https://zotopie.com";
const pageUrl = `${SITE}/best/${page.slug}/`;

const jsonLdStr = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: page.metaTitle,
      description: page.metaDesc,
      breadcrumb: {
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home", item: `${SITE}/` },
          { "@type": "ListItem", position: 2, name: "Best Tools", item: `${SITE}/best/` },
          { "@type": "ListItem", position: 3, name: page.h1 },
        ],
      },
    },
    {
      "@type": "ItemList",
      name: page.h1,
      description: page.metaDesc,
      numberOfItems: pageTools.length,
      itemListElement: pageTools.map((t, i) => ({
        "@type": "ListItem",
        position: i + 1,
        item: {
          "@type": "SoftwareApplication",
          name: t.name,
          url: `${SITE}/reviews/${t.slug}/`,
          applicationCategory: "WebApplication",
          aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: String(t.rating),
            bestRating: "5",
            worstRating: "1",
            ratingCount: "10",
          },
        },
      })),
    },
    {
      "@type": "FAQPage",
      mainEntity: pageFaqs.map((faq) => ({
        "@type": "Question",
        name: faq.q,
        acceptedAnswer: { "@type": "Answer", text: faq.a },
      })),
    },
  ],
});
---

<MainLayout title={page.metaTitle} description={page.metaDesc}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLdStr} />
  </Fragment>

  <!-- HERO -->
  <section class="best-hero">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>&rsaquo;</span>
      <a href="/best/">Best Tools</a>
      <span>&rsaquo;</span>
      <span aria-current="page">{page.h1}</span>
    </nav>

    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      Editorial Guide &mdash; Updated 2026
    </div>

    <h1>{page.h1}</h1>
    <p class="hero-intro">{page.intro}</p>

    <div class="hero-stats">
      <div class="hstat">
        <span class="hstat-num">{pageTools.length}</span>
        <span class="hstat-label">Tools Reviewed</span>
      </div>
      <div class="hstat-div"></div>
      <div class="hstat">
        <span class="hstat-num">★ {avgRating}</span>
        <span class="hstat-label">Avg Rating</span>
      </div>
      {freeCount > 0 && (
        <>
          <div class="hstat-div"></div>
          <div class="hstat">
            <span class="hstat-num">{freeCount}</span>
            <span class="hstat-label">Free / Freemium</span>
          </div>
        </>
      )}
    </div>
  </section>

  <!-- TOP PICK BANNER -->
  {winner && (
    <section class="top-pick-banner">
      <div class="tp-label">
        <span class="tp-crown">★</span> Editor's Top Pick
      </div>
      <div class="tp-content">
        <ToolLogo tool={winner} size={48} />
        <div class="tp-body">
          <div class="tp-name">{winner.name}</div>
          <div class="tp-tag">{rankLabels[winner.slug]}</div>
          <p class="tp-desc">{winner.description}</p>
        </div>
        <div class="tp-actions">
          <a href={`/go/${winner.slug}`}
             class="tp-cta-primary"
             rel={winner.affiliate ? "sponsored noopener" : "noopener"}
             target="_blank">
            {winner.pricing === "Free" || winner.pricing === "Freemium"
              ? `Try ${winner.name} Free →`
              : `Visit ${winner.name} →`}
          </a>
          <a href={`/reviews/${winner.slug}/`} class="tp-cta-sec">Read Full Review →</a>
        </div>
      </div>
    </section>
  )}

  <!-- COMPARISON TABLE -->
  <section class="best-section">
    <h2>Quick Comparison</h2>
    <div class="cmp-table-wrap">
      <table class="cmp-table">
        <thead>
          <tr>
            <th class="col-rank">Rank</th>
            <th>Tool</th>
            <th>Rating</th>
            <th>Pricing</th>
            <th>Free Plan</th>
            <th>Best For</th>
          </tr>
        </thead>
        <tbody>
          {pageTools.map((tool, i) => {
            const isFree = tool.pricing === "Free" || tool.pricing === "Freemium";
            return (
              <tr class={i === 0 ? "row-winner" : ""}>
                <td class="col-rank">
                  <span class:list={["rank-pill", `rank-${i + 1}`]}>#{i + 1}</span>
                </td>
                <td>
                  <a href={`/reviews/${tool.slug}/`} class="tbl-tool-link">
                    <ToolLogo tool={tool} size={24} />
                    <span class="tbl-tool-name">{tool.name}</span>
                    {i === 0 && <span class="tbl-winner-badge">Top Pick</span>}
                  </a>
                </td>
                <td><span class="tbl-rating">★ {tool.rating}</span></td>
                <td><span class:list={["tbl-price", { "tbl-price-free": isFree }]}>{formatPricing(tool)}</span></td>
                <td class={isFree ? "cell-yes" : "cell-no"}>{isFree ? "✓ Yes" : "✗ No"}</td>
                <td class="tbl-bestfor">{rankLabels[tool.slug]}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- RANKED TOOL SECTIONS -->
  <section class="best-section">
    <h2>All {pageTools.length} Tools Ranked</h2>

    <div class="tool-list">
      {pageTools.map((tool, i) => {
        const isFree = tool.pricing === "Free" || tool.pricing === "Freemium";
        const rankLabel = rankLabels[tool.slug] ?? "";
        const whyText = tool.pros && tool.pros.length > 0
          ? `${tool.name} earns the "${rankLabel}" title because: ${tool.pros[0].toLowerCase()}. It is particularly well-suited for ${tool.bestFor?.[0]?.toLowerCase() ?? "its core use case"}.`
          : tool.overview?.slice(0, 200) + "…";

        // Compare pairs involving this tool (vs higher-ranked tools only)
        const toolComparePairs = comparePairs.filter(
          (p) => p.slug.includes(tool.slug)
        ).slice(0, 2);

        return (
          <div class:list={["tool-entry", { "tool-entry-top": i === 0 }]}>
            <div class="te-rank-col">
              <span class:list={["te-rank", `te-rank-${i + 1}`]}>#{i + 1}</span>
            </div>

            <div class="te-body">
              <div class="te-header">
                <div class="te-id">
                  <ToolLogo tool={tool} size={40} />
                  <div>
                    <div class="te-name">{tool.name}</div>
                    <div class="te-label">{rankLabel}</div>
                  </div>
                </div>
                <div class="te-badges">
                  <span class:list={["te-rating", { "te-rating-top": i === 0 }]}>★ {tool.rating}</span>
                  <span class:list={["te-price", { "te-price-free": isFree }]}>{formatPricing(tool)}</span>
                </div>
              </div>

              <p class="te-desc">{tool.description}</p>

              <div class="te-why">
                <span class="te-why-label">Why #{i + 1}:</span>
                <span class="te-why-text">{whyText}</span>
              </div>

              {(tool.pros?.length > 0 || tool.cons?.length > 0) && (
                <div class="te-proscons">
                  {tool.pros?.length > 0 && (
                    <div class="te-pros">
                      <div class="pc-label pros-lbl">Pros</div>
                      <ul class="pc-list">
                        {tool.pros.slice(0, 3).map((p) => <li>{p}</li>)}
                      </ul>
                    </div>
                  )}
                  {tool.cons?.length > 0 && (
                    <div class="te-cons">
                      <div class="pc-label cons-lbl">Cons</div>
                      <ul class="pc-list">
                        {tool.cons.slice(0, 2).map((c) => <li>{c}</li>)}
                      </ul>
                    </div>
                  )}
                </div>
              )}

              {tool.bestFor?.length > 0 && (
                <div class="te-bestfor">
                  <span class="te-bestfor-label">Best for:</span>
                  {tool.bestFor.slice(0, 3).map((b) => (
                    <span class="te-bestfor-tag">{b}</span>
                  ))}
                </div>
              )}

              <div class="te-actions">
                <a href={`/go/${tool.slug}`}
                   class="te-btn-primary"
                   rel={tool.affiliate ? "sponsored noopener" : "noopener"}
                   target="_blank">
                  {isFree ? `Try ${tool.name} Free →` : `Visit ${tool.name} →`}
                </a>
                <a href={`/reviews/${tool.slug}/`} class="te-btn-sec">Full Review →</a>
                <a href={`/alternatives/${tool.slug}/`} class="te-btn-alt">Alternatives →</a>
                {toolComparePairs.map((pair) => (
                  <a href={`/compare/${pair.slug}/`} class="te-btn-cmp">{pair.label} →</a>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- HOW WE RANK -->
  <section class="best-section how-section">
    <h2>How We Ranked These Tools</h2>
    <div class="how-grid">
      <div class="how-item">
        <div class="how-num">01</div>
        <div class="how-body">
          <div class="how-title">Editorial Rating</div>
          <p>Each tool is scored 1â€“5 based on feature depth, performance benchmarks, and real-world usability.</p>
        </div>
      </div>
      <div class="how-item">
        <div class="how-num">02</div>
        <div class="how-body">
          <div class="how-title">Pricing Value</div>
          <p>We evaluate what you get per dollar — free plan quality, paid tier value, and hidden costs.</p>
        </div>
      </div>
      <div class="how-item">
        <div class="how-num">03</div>
        <div class="how-body">
          <div class="how-title">Use Case Fit</div>
          <p>Rankings reflect specific audiences. A tool ranked #1 for agencies may be ranked differently for solo creators.</p>
        </div>
      </div>
      <div class="how-item">
        <div class="how-num">04</div>
        <div class="how-body">
          <div class="how-title">Independence</div>
          <p>Affiliate relationships never affect rankings. Some links earn us a commission at no cost to you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="best-section faq-section">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      {pageFaqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-q">
            <span>{faq.q}</span>
            <svg class="faq-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </summary>
          <div class="faq-a">{faq.a}</div>
        </details>
      ))}
    </div>
  </section>

  <!-- RELATED COMPARISONS -->
  {comparePairs.length > 0 && (
    <section class="best-section explore-section">
      <h2>Compare Top {page.categoryName} Tools</h2>
      <div class="compare-links">
        {comparePairs.map((pair) => (
          <a href={`/compare/${pair.slug}/`} class="compare-pill">
            {pair.label} →
          </a>
        ))}
        <a href={`/category/${page.categorySlug}/`} class="compare-pill compare-pill-cat">
          Browse all {page.categoryName} tools →
        </a>
      </div>
    </section>
  )}

  <!-- FOOTER NAV -->
  <section class="best-footer-nav">
    <p>
      <a href={`/category/${page.categorySlug}/`}>← All {page.categoryName} tools</a>
      &nbsp;&bull;&nbsp;
      <a href="/best/">More best-of guides →</a>
    </p>
  </section>
</MainLayout>

<style>
  /* HERO */
