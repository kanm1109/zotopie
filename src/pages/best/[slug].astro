  .tp-crown { font-size: 0.9rem; }
  .tp-content {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    flex-wrap: wrap;
  }
  .tp-body { flex: 1; min-width: 200px; }
  .tp-name { font-size: 1.25rem; font-weight: 800; color: #111827; margin-bottom: 4px; }
