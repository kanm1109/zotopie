  .cmp-table tbody tr:hover { background: #F5F3FF; }
  .row-winner { background: #fffbeb !important; }
  .row-winner:hover { background: #fef3c7 !important; }
  .col-rank { width: 64px; text-align: center; }
  .rank-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px; height: 32px;
    border-radius: 50%;
    font-size: 0.78rem;
    font-weight: 700;
    background: #f3f4f6;
    color: #6b7280;
  }
  .rank-1 { background: linear-gradient(135deg, #fef3c7, #fde68a); color: #92400e; }
  .rank-2 { background: #f3f4f6; color: #6b7280; }
  .rank-3 { background: #fed7aa; color: #9a3412; }
  .tbl-tool-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #111827;
    font-weight: 600;
  }
  .tbl-tool-link:hover { color: #7C3AED; text-decoration: none; }
  .tbl-tool-name { font-size: 0.9rem; }
  .tbl-winner-badge {
    font-size: 0.65rem;
    font-weight: 700;
    background: linear-gradient(90deg, #f59e0b, #d97706);
    color: #fff;
    padding: 2px 7px;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .tbl-rating {
    font-size: 0.85rem;
    font-weight: 700;
    color: #92400e;
    background: #fef3c7;
    padding: 2px 8px;
    border-radius: 10px;
    white-space: nowrap;
  }
  .tbl-price {
    font-size: 0.8rem;
    font-weight: 600;
    color: #6b7280;
    background: #f3f4f6;
    padding: 2px 8px;
    border-radius: 10px;
    white-space: nowrap;
  }
  .tbl-price-free { color: #059669; background: #dcfce7; }
  .cell-yes { color: #059669; font-weight: 700; }
  .cell-no { color: #d1d5db; }
  .tbl-bestfor { font-size: 0.82rem; color: #6b7280; }
  .cmp-table tr:last-child td { border-bottom: none; }

