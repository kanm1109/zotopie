---
const {
  title = "Zotopie",
  description = "Find reviews, comparisons and alternatives for the best software tools.",
  canonical,
  image,
} = Astro.props;
const SITE = (Astro.site?.origin) ?? "https://zotopie.com";
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site ?? SITE).href;
const ogImage = image
  ? (image.startsWith("http") ? image : `${SITE}${image}`)
  : `${SITE}/og-default.svg`;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Zotopie" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/svg+xml" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: Arial, sans-serif;
      color: #111827;
      background: #fff;
      line-height: 1.6;
    }
    a { color: #2563eb; text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* NAV */
    .site-header {
      border-bottom: 1px solid #e5e7eb;
      background: #fff;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }
    .nav-logo {
      font-size: 1.25rem;
      font-weight: 700;
      color: #111827;
      letter-spacing: -0.5px;
    }
    .nav-logo:hover { text-decoration: none; }
    .nav-links { display: flex; align-items: center; gap: 28px; }
    .nav-links a { font-size: 0.95rem; color: #374151; font-weight: 500; }
    .nav-links a:hover { color: #2563eb; text-decoration: none; }
    .nav-right { display: flex; align-items: center; gap: 20px; }
    .nav-search-form { position: relative; display: flex; align-items: center; }
    .nav-s-icon { position: absolute; left: 10px; pointer-events: none; flex-shrink: 0; }
    .nav-s-input {
      width: 200px;
      padding: 7px 36px 7px 32px;
      font-size: 0.875rem;
      border: 1.5px solid #e5e7eb;
      border-radius: 20px;
      background: #f9fafb;
      color: #111827;
      outline: none;
      font-family: inherit;
      transition: width 0.25s, border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .nav-s-input::placeholder { color: #9ca3af; }
    .nav-s-input:focus {
      width: 260px;
      border-color: #2563eb;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }
    .nav-s-kbd {
      position: absolute; right: 10px;
      font-size: 0.7rem; color: #9ca3af;
      background: #f3f4f6; border: 1px solid #e5e7eb;
      border-radius: 4px; padding: 1px 5px;
      pointer-events: none; font-family: inherit;
      transition: opacity 0.15s;
    }
    .nav-s-input:focus + .nav-s-kbd { opacity: 0; }
    .nav-s-mobile { display: none; color: #6b7280; padding: 4px; }
    @media (max-width: 768px) {
      .nav-search-form { display: none; }
      .nav-s-mobile { display: flex; align-items: center; }
    }

    /* MAIN WRAPPER */
    .page-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px 64px;
    }

    /* FOOTER */
    .site-footer {
      border-top: 1px solid #e5e7eb;
      background: #f9fafb;
      padding: 32px 24px;
      text-align: center;
      font-size: 0.875rem;
      color: #6b7280;
    }
    .footer-disclosure {
      margin-top: 8px;
      font-size: 0.78rem;
      color: #9ca3af;
      max-width: 640px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.5;
    }
  </style>
  <slot name="head" />
</head>

<body>
  <header class="site-header">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Zotopie</a>
      <div class="nav-right">
        <nav class="nav-links">
          <a href="/">Home</a>
          <a href="/category">Categories</a>
          <a href="/reviews">Reviews</a>
        </nav>
        <form class="nav-search-form" action="/search" method="get" role="search">
          <svg class="nav-s-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input id="nav-q" name="q" type="text" placeholder="Search tools…"
            autocomplete="off" spellcheck="false" class="nav-s-input" aria-label="Search tools" />
          <kbd class="nav-s-kbd" aria-hidden="true">/</kbd>
        </form>
        <a href="/search" class="nav-s-mobile" aria-label="Search tools">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </a>
      </div>
    </div>
  </header>

  <div class="page-wrapper">
    <slot />
  </div>

  <footer class="site-footer">
    <p>&copy; {new Date().getFullYear()} Zotopie &mdash; Find the best software tools</p>
    <p class="footer-disclosure">
      Some links on this site are affiliate links. We may earn a commission when you click through and make a purchase &mdash; at no extra cost to you.
      Our editorial ratings and recommendations are independent of affiliate relationships.
    </p>
  </footer>
  <script>
    document.addEventListener('keydown', function(e) {
      var tag = document.activeElement && document.activeElement.tagName;
      if (e.key === '/' && tag !== 'INPUT' && tag !== 'TEXTAREA' && tag !== 'SELECT') {
        e.preventDefault();
        var navQ = document.getElementById('nav-q');
        if (navQ) navQ.focus();
      }
    });
  </script>
</body>
</html>
