---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_URL } from '../consts';

interface Props {
	title: string;
	description: string;
	publishDate: Date;
	updatedDate?: Date;
	author?: string;
	tags?: string[];
	category: string;
	categoryName?: string;
	featuredImage?: ImageMetadata;
}

const {
	title,
	description,
	publishDate,
	updatedDate,
	author = 'Zotopie Team',
	tags = [],
	category,
	categoryName,
	featuredImage,
} = Astro.props;

const displayCategory = categoryName ?? category;
const breadcrumbs = [
	{ name: displayCategory, url: `${SITE_URL}/${category}/` },
	{ name: title, url: Astro.url.href },
];
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={featuredImage}
			type="article"
			publishDate={publishDate}
			updatedDate={updatedDate}
			author={author}
			tags={tags}
			breadcrumbs={breadcrumbs}
		/>
	</head>
	<body>
		<Header />
		<main>
			<article class="article-wrap">
				<div class="article-header">
					<Breadcrumb items={[
						{ name: displayCategory, url: `/${category}/` },
						{ name: title, url: Astro.url.pathname },
					]} />
					{tags.length > 0 && (
						<div class="tags-row">
							{tags.map((tag) => (
								<a href={`/tags/${tag}/`} class="tag">#{tag}</a>
							))}
						</div>
					)}
					<h1>{title}</h1>
					<div class="meta">
						<span>By {author}</span>
						<span class="dot">·</span>
						<FormattedDate date={publishDate} />
						{updatedDate && (
							<>
								<span class="dot">·</span>
								<span>Updated <FormattedDate date={updatedDate} /></span>
							</>
						)}
					</div>
				</div>
				{featuredImage && (
					<div class="hero">
						<Image src={featuredImage} alt={title} width={1200} height={630} />
					</div>
				)}
				<div class="prose">
					<slot />
				</div>
				{tags.length > 0 && (
					<div class="footer-tags">
						<strong>Tags:</strong>
						{tags.map((tag) => (
							<a href={`/tags/${tag}/`} class="tag">#{tag}</a>
						))}
					</div>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.article-wrap {
		max-width: 780px;
		margin: 0 auto;
		padding: 2rem 1rem 4rem;
	}
	.article-header { margin-bottom: 2rem; }
	.tags-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}
	.tag {
		color: var(--accent);
		text-decoration: none;
		font-size: 0.85rem;
	}
	.tag:hover { text-decoration: underline; }
	h1 {
		font-size: 2.4rem;
		line-height: 1.15;
		margin: 0.5rem 0 1rem;
	}
	.meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}
	.dot { color: rgb(var(--gray)); }
	.hero {
		margin-bottom: 2.5rem;
		border-radius: 12px;
		overflow: hidden;
	}
	.hero img { width: 100%; height: auto; border-radius: 0; }
	.prose { font-size: 1.05rem; line-height: 1.8; }
	.footer-tags {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgb(var(--gray-light));
		font-size: 0.9rem;
	}
	@media (max-width: 720px) {
		h1 { font-size: 1.8rem; }
		.article-wrap { padding: 1rem 1rem 3rem; }
	}
</style>
